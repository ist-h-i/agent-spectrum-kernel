{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ai-skills-metrics-record --hook-event PostToolUse --event-kind verification_attempt"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ai-skills-metrics-record --hook-event Stop --event-kind task_stop"
          }
        ]
      }
    ]
  }
}
