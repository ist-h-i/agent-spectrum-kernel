{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "test -x \"${CLAUDE_PLUGIN_ROOT}/bin/ai-skills-metrics-record\" && \"${CLAUDE_PLUGIN_ROOT}/bin/ai-skills-metrics-record\" --hook-event PostToolUse --event-kind verification_attempt --non-blocking >/dev/null 2>&1 || true # agent-spectrum-kernel:claude-plugin-hook"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -x \"${CLAUDE_PLUGIN_ROOT}/bin/ai-skills-metrics-record\" && \"${CLAUDE_PLUGIN_ROOT}/bin/ai-skills-metrics-record\" --hook-event Stop --event-kind task_stop --non-blocking >/dev/null 2>&1 || true # agent-spectrum-kernel:claude-plugin-hook"
          }
        ]
      }
    ]
  }
}
