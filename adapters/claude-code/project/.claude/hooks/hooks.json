{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/scripts/ai-metrics-record.mjs --hook-event PostToolUse --event-kind file_change"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/scripts/ai-metrics-record.mjs --hook-event PostToolUse --event-kind file_change"
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/scripts/ai-metrics-record.mjs --hook-event PostToolUse --event-kind file_change"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/scripts/ai-metrics-record.mjs --hook-event PostToolUse --event-kind verification_attempt"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/scripts/ai-metrics-record.mjs --hook-event Stop --event-kind task_stop"
          }
        ]
      }
    ]
  }
}
