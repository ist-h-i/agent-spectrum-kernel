{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/scripts/ai-metrics-record.mjs --hook-event PostToolUse --event-kind file_change --non-blocking >/dev/null 2>&1 || true"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/scripts/ai-metrics-record.mjs --hook-event PostToolUse --event-kind file_change --non-blocking >/dev/null 2>&1 || true"
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/scripts/ai-metrics-record.mjs --hook-event PostToolUse --event-kind file_change --non-blocking >/dev/null 2>&1 || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/scripts/ai-metrics-record.mjs --hook-event PostToolUse --event-kind verification_attempt --non-blocking >/dev/null 2>&1 || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PROJECT_DIR}/scripts/ai-metrics-record.mjs --hook-event Stop --event-kind task_stop --sidecar ${CLAUDE_PROJECT_DIR}/.claude/metrics/current-task.json --non-blocking >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  }
}
