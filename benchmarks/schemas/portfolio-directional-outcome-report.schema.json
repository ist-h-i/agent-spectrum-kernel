{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-spectrum-kernel.invalid/schemas/portfolio-directional-outcome-report.schema.json",
  "title": "Adaptive ASK Portfolio Directional Outcome Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "schema_path", "program", "authority", "comparison_view_definitions", "fixture_outcomes", "boundaries", "directional_outcome_report_id", "directional_outcome_report_digest"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "schema_path": { "const": "benchmarks/schemas/portfolio-directional-outcome-report.schema.json" },
    "program": { "const": "adaptive_ask_portfolio_directional_outcome_report" },
    "authority": { "$ref": "#/$defs/authority" },
    "comparison_view_definitions": { "type": "array", "minItems": 3, "maxItems": 3, "uniqueItems": true, "items": { "$ref": "#/$defs/viewDefinition" } },
    "fixture_outcomes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/fixtureOutcome" } },
    "boundaries": { "$ref": "#/$defs/boundaries" },
    "directional_outcome_report_id": { "type": "string", "pattern": "^directional-outcome-report-[a-f0-9]{32}$" },
    "directional_outcome_report_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "token": { "type": "string", "minLength": 1, "maxLength": 160 },
    "condition": { "enum": ["plain", "kernel_only", "adaptive_ask", "full_ask"] },
    "viewDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["view_id", "comparison_condition", "baseline_condition", "view_role"],
      "properties": {
        "view_id": { "enum": ["kernel_vs_plain", "adaptive_vs_kernel", "full_vs_kernel_diagnostic"] },
        "comparison_condition": { "$ref": "#/$defs/condition" },
        "baseline_condition": { "$ref": "#/$defs/condition" },
        "view_role": { "enum": ["primary_product_hypothesis", "diagnostic_only"] }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paired_comparison_report_id", "paired_comparison_report_digest", "repetition_report_id", "repetition_report_digest", "result_set_id", "result_set_digest", "source_manifest_raw_byte_digest", "source_manifest_digest", "normalized_generation_id", "normalized_manifest_digest", "source_snapshot_digest", "plan_id", "plan_digest", "run_instance_id", "source_revision", "adapter_track", "scoring_policy_revision", "scoring_policy_digest"],
      "properties": {
        "paired_comparison_report_id": { "type": "string", "pattern": "^paired-comparison-report-[a-f0-9]{32}$" },
        "paired_comparison_report_digest": { "$ref": "#/$defs/digest" },
        "repetition_report_id": { "type": "string", "pattern": "^repetition-report-[a-f0-9]{32}$" },
        "repetition_report_digest": { "$ref": "#/$defs/digest" },
        "result_set_id": { "type": "string", "pattern": "^engineering-result-set-[a-f0-9]{32}$" },
        "result_set_digest": { "$ref": "#/$defs/digest" },
        "source_manifest_raw_byte_digest": { "$ref": "#/$defs/digest" },
        "source_manifest_digest": { "$ref": "#/$defs/digest" },
        "normalized_generation_id": { "type": "string", "pattern": "^snapshot-[a-f0-9]{64}$" },
        "normalized_manifest_digest": { "$ref": "#/$defs/digest" },
        "source_snapshot_digest": { "$ref": "#/$defs/digest" },
        "plan_id": { "type": "string", "pattern": "^plan-[a-f0-9]{64}$" },
        "plan_digest": { "$ref": "#/$defs/digest" },
        "run_instance_id": { "type": "string", "format": "uuid" },
        "source_revision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "adapter_track": { "enum": ["codex", "claude"] },
        "scoring_policy_revision": { "const": "issue-205-checkpoint-b1-r3" },
        "scoring_policy_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "fixtureOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture_id", "fixture_input_digest", "suite", "task_class", "expected_repetition_count", "comparison_views"],
      "properties": {
        "fixture_id": { "$ref": "#/$defs/token" },
        "fixture_input_digest": { "$ref": "#/$defs/digest" },
        "suite": { "enum": ["mechanism_positive", "mechanism_negative", "practice_frequency", "high_impact", "calibration"] },
        "task_class": { "$ref": "#/$defs/token" },
        "expected_repetition_count": { "enum": [3, 5] },
        "comparison_views": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "$ref": "#/$defs/comparisonView" } }
      }
    },
    "comparisonView": {
      "type": "object",
      "additionalProperties": false,
      "required": ["view_id", "comparison_condition", "baseline_condition", "view_role", "expected_pair_count", "observed_pair_count", "comparison_win_count", "comparison_loss_count", "exact_tie_count", "insufficient_evidence_count", "directional_summary_status", "pair_outcomes"],
      "properties": {
        "view_id": { "enum": ["kernel_vs_plain", "adaptive_vs_kernel", "full_vs_kernel_diagnostic"] },
        "comparison_condition": { "$ref": "#/$defs/condition" },
        "baseline_condition": { "$ref": "#/$defs/condition" },
        "view_role": { "enum": ["primary_product_hypothesis", "diagnostic_only"] },
        "expected_pair_count": { "enum": [3, 5] },
        "observed_pair_count": { "enum": [3, 5] },
        "comparison_win_count": { "type": "integer", "minimum": 0, "maximum": 5 },
        "comparison_loss_count": { "type": "integer", "minimum": 0, "maximum": 5 },
        "exact_tie_count": { "type": "integer", "minimum": 0, "maximum": 5 },
        "insufficient_evidence_count": { "type": "integer", "minimum": 0, "maximum": 5 },
        "directional_summary_status": { "enum": ["complete", "insufficient_evidence"] },
        "pair_outcomes": { "type": "array", "minItems": 3, "maxItems": 5, "items": { "$ref": "#/$defs/pairOutcome" } }
      }
    },
    "pairOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repetition", "view_id", "baseline_condition", "comparison_condition", "baseline_engineering_result_id", "baseline_engineering_result_digest", "comparison_engineering_result_id", "comparison_engineering_result_digest", "baseline_normalized_result_id", "baseline_normalized_result_digest", "comparison_normalized_result_id", "comparison_normalized_result_digest", "paired_quality_delta_status", "paired_normalized_quality_delta", "directional_outcome", "outcome_perspective"],
      "properties": {
        "repetition": { "type": "integer", "minimum": 1, "maximum": 5 },
        "view_id": { "enum": ["kernel_vs_plain", "adaptive_vs_kernel", "full_vs_kernel_diagnostic"] },
        "baseline_condition": { "$ref": "#/$defs/condition" },
        "comparison_condition": { "$ref": "#/$defs/condition" },
        "baseline_engineering_result_id": { "type": "string", "pattern": "^engineering-result-[a-f0-9]{32}$" },
        "baseline_engineering_result_digest": { "$ref": "#/$defs/digest" },
        "comparison_engineering_result_id": { "type": "string", "pattern": "^engineering-result-[a-f0-9]{32}$" },
        "comparison_engineering_result_digest": { "$ref": "#/$defs/digest" },
        "baseline_normalized_result_id": { "type": "string", "pattern": "^normalized-[a-f0-9]{32}$" },
        "baseline_normalized_result_digest": { "$ref": "#/$defs/digest" },
        "comparison_normalized_result_id": { "type": "string", "pattern": "^normalized-[a-f0-9]{32}$" },
        "comparison_normalized_result_digest": { "$ref": "#/$defs/digest" },
        "paired_quality_delta_status": { "enum": ["complete", "insufficient_evidence"] },
        "paired_normalized_quality_delta": { "type": ["number", "null"], "minimum": -1, "maximum": 1 },
        "directional_outcome": { "enum": ["comparison_win", "comparison_loss", "exact_tie", "insufficient_evidence"] },
        "outcome_perspective": { "const": "comparison_condition" }
      },
      "allOf": [{
        "if": {
          "properties": { "paired_quality_delta_status": { "const": "complete" } },
          "required": ["paired_quality_delta_status"]
        },
        "then": {
          "properties": {
            "paired_normalized_quality_delta": { "type": "number", "minimum": -1, "maximum": 1 },
            "directional_outcome": { "enum": ["comparison_win", "comparison_loss", "exact_tie"] }
          }
        },
        "else": {
          "properties": {
            "paired_quality_delta_status": { "const": "insufficient_evidence" },
            "paired_normalized_quality_delta": { "type": "null" },
            "directional_outcome": { "const": "insufficient_evidence" }
          }
        }
      }]
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["directional_win_loss_tie_calculated", "meaningful_delta_classified", "meaningful_delta_threshold_applied", "majority_winner_calculated", "win_rate_calculated", "confidence_interval_calculated", "bootstrap_calculated", "probability_of_improvement_calculated", "within_condition_variance_exceedance_classified", "practice_weighting_applied", "lineage_weighting_applied", "mechanism_scorecard_calculated", "cross_fixture_aggregate_calculated", "cross_suite_aggregate_calculated", "cross_adapter_pooling", "ceiling_floor_classification_calculated", "product_value_claim", "measured_execution_authorized", "issue_198_stage_0_authorized"],
      "properties": {
        "directional_win_loss_tie_calculated": { "const": true },
        "meaningful_delta_classified": { "const": false },
        "meaningful_delta_threshold_applied": { "const": false },
        "majority_winner_calculated": { "const": false },
        "win_rate_calculated": { "const": false },
        "confidence_interval_calculated": { "const": false },
        "bootstrap_calculated": { "const": false },
        "probability_of_improvement_calculated": { "const": false },
        "within_condition_variance_exceedance_classified": { "const": false },
        "practice_weighting_applied": { "const": false },
        "lineage_weighting_applied": { "const": false },
        "mechanism_scorecard_calculated": { "const": false },
        "cross_fixture_aggregate_calculated": { "const": false },
        "cross_suite_aggregate_calculated": { "const": false },
        "cross_adapter_pooling": { "const": false },
        "ceiling_floor_classification_calculated": { "const": false },
        "product_value_claim": { "const": false },
        "measured_execution_authorized": { "const": false },
        "issue_198_stage_0_authorized": { "const": false }
      }
    }
  }
}
