{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive ASK sealed pre-result mechanism selection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "plan_digest",
    "materialization_manifest_digest",
    "materialization_output_root_identity",
    "materializer",
    "case_id",
    "block_id",
    "adapter",
    "condition",
    "fixture",
    "repetition",
    "registered_repetitions",
    "frozen_input_digest",
    "condition_projection_digest",
    "projection_fingerprint",
    "task_class",
    "observed_signals",
    "selected_mechanisms",
    "skipped_mechanisms",
    "required_gates",
    "agents",
    "expected_evidence",
    "capability_downgrades",
    "lightweight_bypass",
    "projection",
    "selected_at",
    "selection_digest"
  ],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "plan_id": { "type": "string", "pattern": "^plan-[a-f0-9]{64}$" },
    "plan_digest": { "$ref": "#/$defs/prefixedDigest" },
    "materialization_manifest_digest": { "$ref": "#/$defs/prefixedDigest" },
    "materialization_output_root_identity": { "$ref": "#/$defs/prefixedDigest" },
    "materializer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "source_revision"],
      "properties": {
        "version": { "const": "1.0.0" },
        "source_revision": { "$ref": "#/$defs/revision" }
      }
    },
    "case_id": { "$ref": "#/$defs/caseId" },
    "block_id": { "type": "string", "pattern": "^block-[a-f0-9]{16}-[a-f0-9]{12}$" },
    "adapter": { "enum": ["codex", "claude"] },
    "condition": { "const": "adaptive_ask" },
    "fixture": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "repetition": { "type": "integer", "minimum": 1, "maximum": 5 },
    "registered_repetitions": { "enum": [3, 5] },
    "frozen_input_digest": { "$ref": "#/$defs/prefixedDigest" },
    "condition_projection_digest": { "$ref": "#/$defs/prefixedDigest" },
    "projection_fingerprint": { "$ref": "#/$defs/prefixedDigest" },
    "task_class": { "type": "string", "minLength": 1 },
    "observed_signals": { "$ref": "#/$defs/observedSignalArray" },
    "selected_mechanisms": { "$ref": "#/$defs/nonEmptyStringArray" },
    "skipped_mechanisms": { "$ref": "#/$defs/nonEmptyStringArray" },
    "required_gates": { "$ref": "#/$defs/nonEmptyStringArray" },
    "agents": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested", "omitted"],
      "properties": {
        "requested": { "$ref": "#/$defs/nonEmptyStringArray" },
        "omitted": { "$ref": "#/$defs/nonEmptyStringArray" }
      }
    },
    "expected_evidence": { "$ref": "#/$defs/nonEmptyStringArray" },
    "capability_downgrades": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["capability", "reason"],
        "properties": {
          "capability": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "lightweight_bypass": {
      "type": "object",
      "additionalProperties": false,
      "required": ["used", "reason"],
      "properties": {
        "used": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter_track", "profile", "renderer_id", "renderer_version", "projection_fingerprint"],
      "properties": {
        "adapter_track": { "enum": ["codex", "claude"] },
        "profile": { "type": "string", "minLength": 1 },
        "renderer_id": { "type": "string", "minLength": 1 },
        "renderer_version": { "type": "string", "minLength": 1 },
        "projection_fingerprint": { "$ref": "#/$defs/prefixedDigest" }
      }
    },
    "selected_at": { "type": "string", "format": "date-time" },
    "selection_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "const": "sha256" },
        "value": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  },
  "$defs": {
    "caseId": { "type": "string", "pattern": "^case-[a-f0-9]{16}-[a-f0-9]{16}$" },
    "prefixedDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "revision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "observedSignalArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": ".*\\S.*" }
    },
    "nonEmptyStringArray": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
