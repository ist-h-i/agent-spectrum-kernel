{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive ASK unweighted repeated-run descriptive report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "schema_path", "program", "authority", "fixture_reports", "boundaries", "repetition_report_id", "repetition_report_digest"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "schema_path": { "const": "benchmarks/schemas/portfolio-repetition-report.schema.json" },
    "program": { "const": "adaptive_ask_portfolio_repetition_report" },
    "authority": { "$ref": "#/$defs/authority" },
    "fixture_reports": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/fixtureReport" } },
    "boundaries": { "$ref": "#/$defs/boundaries" },
    "repetition_report_id": { "type": "string", "pattern": "^repetition-report-[a-f0-9]{32}$" },
    "repetition_report_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "count": { "type": "integer", "minimum": 0 },
    "token": { "type": "string", "minLength": 1, "maxLength": 160 },
    "portablePath": { "type": "string", "minLength": 1, "maxLength": 240, "pattern": "^(?!/)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)[^\\u0000]+$" },
    "authority": {
      "type": "object", "additionalProperties": false,
      "required": ["result_set_id", "result_set_digest", "source_manifest_raw_byte_digest", "source_manifest_digest", "normalized_generation_id", "normalized_manifest_digest", "source_snapshot_digest", "plan_id", "plan_digest", "run_instance_id", "source_revision", "adapter_track", "scoring_policy_revision", "scoring_policy_digest"],
      "properties": {
        "result_set_id": { "type": "string", "pattern": "^engineering-result-set-[a-f0-9]{32}$" }, "result_set_digest": { "$ref": "#/$defs/digest" },
        "source_manifest_raw_byte_digest": { "$ref": "#/$defs/digest" }, "source_manifest_digest": { "$ref": "#/$defs/digest" },
        "normalized_generation_id": { "type": "string", "pattern": "^snapshot-[a-f0-9]{64}$" }, "normalized_manifest_digest": { "$ref": "#/$defs/digest" },
        "source_snapshot_digest": { "$ref": "#/$defs/digest" }, "plan_id": { "type": "string", "pattern": "^plan-[a-f0-9]{64}$" }, "plan_digest": { "$ref": "#/$defs/digest" },
        "run_instance_id": { "type": "string", "format": "uuid" }, "source_revision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "adapter_track": { "enum": ["codex", "claude"] }, "scoring_policy_revision": { "const": "issue-205-checkpoint-b1-r3" }, "scoring_policy_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "fixtureReport": {
      "type": "object", "additionalProperties": false,
      "required": ["fixture_id", "fixture_input_digest", "suite", "task_class", "expected_repetition_count", "condition_reports"],
      "properties": {
        "fixture_id": { "$ref": "#/$defs/token" }, "fixture_input_digest": { "$ref": "#/$defs/digest" },
        "suite": { "enum": ["mechanism_positive", "mechanism_negative", "practice_frequency", "high_impact", "calibration"] }, "task_class": { "$ref": "#/$defs/token" },
        "expected_repetition_count": { "enum": [3, 5] },
        "condition_reports": { "type": "array", "minItems": 4, "maxItems": 4, "items": { "$ref": "#/$defs/conditionReport" } }
      }
    },
    "conditionReport": {
      "type": "object", "additionalProperties": false,
      "required": ["condition", "repetition_observations", "score_distribution", "blocker_counts", "safety_counts", "overhead_distributions", "raw_categorical_summaries"],
      "properties": {
        "condition": { "enum": ["plain", "kernel_only", "adaptive_ask", "full_ask"] },
        "repetition_observations": { "type": "array", "minItems": 3, "maxItems": 5, "items": { "$ref": "#/$defs/observation" } },
        "score_distribution": { "$ref": "#/$defs/distribution" }, "blocker_counts": { "$ref": "#/$defs/blockerCounts" }, "safety_counts": { "$ref": "#/$defs/safetyCounts" },
        "overhead_distributions": { "$ref": "#/$defs/overheadDistributions" }, "raw_categorical_summaries": { "$ref": "#/$defs/rawSummaries" }
      }
    },
    "observation": {
      "type": "object", "additionalProperties": false,
      "required": ["repetition", "path", "raw_byte_digest", "bytes", "engineering_result_id", "engineering_result_digest", "normalized_result_id", "normalized_result_digest", "evaluation_id", "evaluation_digest", "normalized_outcome", "evaluation_status", "scoring_status", "scoring_reason", "blocker_gate_status", "safety_blocker_status", "requirement_score", "false_positive_raw_count", "false_positive_severity_counts", "scope_deviation_raw_count", "correctness_observations", "unsafe_action_category_counts", "mechanism_observations", "overhead_telemetry"],
      "properties": {
        "repetition": { "type": "integer", "minimum": 1, "maximum": 5 }, "path": { "$ref": "#/$defs/portablePath" }, "raw_byte_digest": { "$ref": "#/$defs/digest" }, "bytes": { "type": "integer", "minimum": 1 },
        "engineering_result_id": { "type": "string", "pattern": "^engineering-result-[a-f0-9]{32}$" }, "engineering_result_digest": { "$ref": "#/$defs/digest" },
        "normalized_result_id": { "type": "string", "pattern": "^normalized-[a-f0-9]{32}$" }, "normalized_result_digest": { "$ref": "#/$defs/digest" },
        "evaluation_id": { "type": "string", "pattern": "^evaluation-[a-f0-9]{32}$" }, "evaluation_digest": { "$ref": "#/$defs/digest" },
        "normalized_outcome": { "enum": ["completed", "failed", "unavailable", "interrupted", "invalid"] }, "evaluation_status": { "enum": ["completed", "invalid_input", "evaluator_unavailable", "evaluator_failed", "manual_review_required"] },
        "scoring_status": { "enum": ["complete", "not_scoring_ready"] }, "scoring_reason": { "$ref": "#/$defs/token" },
        "blocker_gate_status": { "enum": ["pass", "fail", "not_applicable", "not_scoring_ready"] }, "safety_blocker_status": { "enum": ["pass", "fail", "unknown", "not_scoring_ready"] },
        "requirement_score": { "type": "object" }, "false_positive_raw_count": { "$ref": "#/$defs/count" }, "false_positive_severity_counts": { "type": "object" },
        "scope_deviation_raw_count": { "$ref": "#/$defs/count" }, "correctness_observations": { "type": "object" }, "unsafe_action_category_counts": { "type": "array" },
        "mechanism_observations": { "type": "object" }, "overhead_telemetry": { "type": "object" }
      }
    },
    "distribution": {
      "type": "object", "additionalProperties": false,
      "required": ["distribution_status", "sample_count", "mean", "median", "minimum", "maximum", "population_variance", "population_standard_deviation"],
      "properties": {
        "distribution_status": { "enum": ["complete", "insufficient_evidence"] }, "sample_count": { "$ref": "#/$defs/count" },
        "mean": { "type": ["number", "null"] }, "median": { "type": ["number", "null"] }, "minimum": { "type": ["number", "null"] }, "maximum": { "type": ["number", "null"] },
        "population_variance": { "type": ["number", "null"] }, "population_standard_deviation": { "type": ["number", "null"] }
      }
    },
    "metricDistribution": {
      "type": "object", "additionalProperties": false,
      "required": ["unit", "distribution_status", "sample_count", "mean", "median", "minimum", "maximum", "population_variance", "population_standard_deviation"],
      "properties": {
        "unit": { "enum": ["milliseconds", "tokens", "native_cost", "native_effort", "count", "bytes"] },
        "distribution_status": { "enum": ["complete", "insufficient_evidence"] }, "sample_count": { "$ref": "#/$defs/count" },
        "mean": { "type": ["number", "null"] }, "median": { "type": ["number", "null"] }, "minimum": { "type": ["number", "null"] }, "maximum": { "type": ["number", "null"] },
        "population_variance": { "type": ["number", "null"] }, "population_standard_deviation": { "type": ["number", "null"] }
      }
    },
    "overheadDistributions": {
      "type": "object", "additionalProperties": false,
      "required": ["duration_ms", "input_tokens", "output_tokens", "cached_tokens", "monetary_cost", "human_effort", "tool_call_count", "file_read_count", "final_output_bytes", "runtime_agent_count", "harness_spawned_secondary_agent_count", "subagent_activity", "capability_downgrade_count"],
      "properties": {
        "duration_ms": { "$ref": "#/$defs/metricDistribution" }, "input_tokens": { "$ref": "#/$defs/metricDistribution" }, "output_tokens": { "$ref": "#/$defs/metricDistribution" }, "cached_tokens": { "$ref": "#/$defs/metricDistribution" },
        "monetary_cost": { "$ref": "#/$defs/metricDistribution" }, "human_effort": { "$ref": "#/$defs/metricDistribution" }, "tool_call_count": { "$ref": "#/$defs/metricDistribution" }, "file_read_count": { "$ref": "#/$defs/metricDistribution" },
        "final_output_bytes": { "$ref": "#/$defs/metricDistribution" }, "runtime_agent_count": { "$ref": "#/$defs/metricDistribution" }, "harness_spawned_secondary_agent_count": { "$ref": "#/$defs/metricDistribution" },
        "subagent_activity": { "$ref": "#/$defs/metricDistribution" }, "capability_downgrade_count": { "$ref": "#/$defs/metricDistribution" }
      }
    },
    "blockerCounts": { "type": "object", "additionalProperties": false, "required": ["pass", "fail", "not_applicable", "not_scoring_ready"], "properties": { "pass": { "$ref": "#/$defs/count" }, "fail": { "$ref": "#/$defs/count" }, "not_applicable": { "$ref": "#/$defs/count" }, "not_scoring_ready": { "$ref": "#/$defs/count" } } },
    "safetyCounts": { "type": "object", "additionalProperties": false, "required": ["pass", "fail", "unknown", "not_scoring_ready"], "properties": { "pass": { "$ref": "#/$defs/count" }, "fail": { "$ref": "#/$defs/count" }, "unknown": { "$ref": "#/$defs/count" }, "not_scoring_ready": { "$ref": "#/$defs/count" } } },
    "rawSummaries": {
      "type": "object", "additionalProperties": false,
      "required": ["false_positive_raw_count", "false_positive_severity_counts", "scope_deviation_raw_count", "correctness_state_counts", "unsafe_action_category_counts", "mechanism_state_counts"],
      "properties": { "false_positive_raw_count": { "$ref": "#/$defs/count" }, "false_positive_severity_counts": { "type": "object" }, "scope_deviation_raw_count": { "$ref": "#/$defs/count" }, "correctness_state_counts": { "type": "object" }, "unsafe_action_category_counts": { "type": "array" }, "mechanism_state_counts": { "type": "object" } }
    },
    "boundaries": {
      "type": "object", "additionalProperties": false,
      "required": ["condition_comparison_calculated", "win_loss_tie_calculated", "confidence_interval_calculated", "bootstrap_calculated", "practice_weighting_applied", "mechanism_scorecard_calculated", "cross_fixture_aggregate_calculated", "cross_adapter_pooling", "product_value_claim", "measured_execution_authorized", "issue_198_stage_0_authorized"],
      "properties": {
        "condition_comparison_calculated": { "const": false }, "win_loss_tie_calculated": { "const": false }, "confidence_interval_calculated": { "const": false }, "bootstrap_calculated": { "const": false },
        "practice_weighting_applied": { "const": false }, "mechanism_scorecard_calculated": { "const": false }, "cross_fixture_aggregate_calculated": { "const": false }, "cross_adapter_pooling": { "const": false },
        "product_value_claim": { "const": false }, "measured_execution_authorized": { "const": false }, "issue_198_stage_0_authorized": { "const": false }
      }
    }
  }
}
