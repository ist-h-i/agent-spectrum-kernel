{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive ASK sealed per-command execution evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "schema_path", "program", "run_instance_id", "case_id", "attempt", "adapter", "condition", "fixture_id", "repetition", "fixture_input_digest", "verification_command_contract_digest", "runtime_identity_digest", "effective_command_digest", "capture", "stream", "command_event_count", "commands", "privacy", "manifest_digest"],
  "properties": {
    "schema_version": { "const": "1.1.0" },
    "schema_path": { "const": "benchmarks/schemas/portfolio-command-evidence.schema.json" },
    "program": { "const": "adaptive_ask_command_evidence" },
    "run_instance_id": { "type": "string", "format": "uuid" },
    "case_id": { "type": "string", "pattern": "^case-[a-f0-9]{16}-[a-f0-9]{16}$" },
    "attempt": { "type": "string", "pattern": "^[0-9]{4}$" },
    "adapter": { "enum": ["codex", "claude"] },
    "condition": { "enum": ["plain", "kernel_only", "adaptive_ask", "full_ask"] },
    "fixture_id": { "$ref": "#/$defs/token" },
    "repetition": { "type": "integer", "minimum": 1, "maximum": 5 },
    "fixture_input_digest": { "$ref": "#/$defs/digest" },
    "verification_command_contract_digest": { "oneOf": [{ "$ref": "#/$defs/digest" }, { "type": "null" }] },
    "runtime_identity_digest": { "$ref": "#/$defs/digest" },
    "effective_command_digest": { "$ref": "#/$defs/digest" },
    "capture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["support", "evidence_level", "event_transport", "event_format_revision", "parser_revision", "contract_probe_evidence", "downgrade_reason"],
      "properties": {
        "support": { "enum": ["supported", "unsupported", "unknown"] },
        "evidence_level": { "enum": ["executed", "unavailable"] },
        "event_transport": { "enum": ["codex_exec_jsonl", "none"] },
        "event_format_revision": { "type": ["string", "null"], "pattern": "^[0-9A-Za-z._-]+$" },
        "parser_revision": { "type": ["string", "null"], "pattern": "^[0-9A-Za-z._-]+$" },
        "contract_probe_evidence": { "enum": ["local_version_help_json_probe", "adapter_event_contract_not_implemented", "runtime_unavailable", "capture_invalid", "command_contract_unavailable"] },
        "downgrade_reason": { "type": ["string", "null"], "minLength": 1, "maxLength": 160, "pattern": "^[a-z0-9][a-z0-9_.:-]*$" }
      },
      "allOf": [
        {
          "if": { "properties": { "evidence_level": { "const": "executed" } }, "required": ["evidence_level"] },
          "then": { "properties": { "support": { "const": "supported" }, "event_transport": { "const": "codex_exec_jsonl" }, "event_format_revision": { "const": "codex-exec-jsonl-v1" }, "parser_revision": { "const": "1.1.0" }, "contract_probe_evidence": { "const": "local_version_help_json_probe" }, "downgrade_reason": { "type": "null" } } },
          "else": {
            "if": { "properties": { "support": { "const": "supported" } }, "required": ["support"] },
            "then": { "properties": { "event_transport": { "const": "codex_exec_jsonl" }, "event_format_revision": { "const": "codex-exec-jsonl-v1" }, "parser_revision": { "const": "1.1.0" }, "downgrade_reason": { "type": "string" } } },
            "else": { "properties": { "event_transport": { "const": "none" }, "event_format_revision": { "type": "null" }, "parser_revision": { "type": "null" }, "downgrade_reason": { "type": "string" } } }
          }
        }
      ]
    },
    "stream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bytes", "digest"],
      "properties": { "bytes": { "type": "integer", "minimum": 0, "maximum": 16777216 }, "digest": { "$ref": "#/$defs/digest" } }
    },
    "command_event_count": { "type": "integer", "minimum": 0, "maximum": 256 },
    "commands": { "type": "array", "maxItems": 128, "items": { "$ref": "#/$defs/commandEvidence" } },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_command_stored", "raw_output_stored", "full_event_stream_stored", "absolute_paths_stored", "secrets_stored"],
      "properties": {
        "raw_command_stored": { "const": false },
        "raw_output_stored": { "const": false },
        "full_event_stream_stored": { "const": false },
        "absolute_paths_stored": { "const": false },
        "secrets_stored": { "const": false }
      }
    },
    "manifest_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "token": { "type": "string", "minLength": 1, "maxLength": 96, "pattern": "^[a-z0-9][a-z0-9_-]*$" },
    "commandEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_evidence_id", "command_evidence_digest", "event_sequence", "runtime_item_id_digest", "matched_command_id", "match_state", "execution_form", "logical_command_digest", "rendered_event_command_digest", "working_directory", "status", "exit_code", "duration", "aggregated_output", "capture_source", "evidence_level", "bytes"],
      "properties": {
        "command_evidence_id": { "type": "string", "pattern": "^command-evidence-[a-f0-9]{32}$" },
        "command_evidence_digest": { "$ref": "#/$defs/digest" },
        "event_sequence": { "type": "object", "additionalProperties": false, "required": ["started", "completed"], "properties": { "started": { "type": "integer", "minimum": 1 }, "completed": { "type": "integer", "minimum": 2 } } },
        "runtime_item_id_digest": { "$ref": "#/$defs/digest" },
        "matched_command_id": { "oneOf": [{ "$ref": "#/$defs/token" }, { "type": "null" }] },
        "match_state": { "enum": ["matched", "unmatched"] },
        "execution_form": { "enum": ["direct_argv", "codex_shell_command"] },
        "logical_command_digest": { "$ref": "#/$defs/digest" },
        "rendered_event_command_digest": { "$ref": "#/$defs/digest" },
        "working_directory": { "type": "object", "additionalProperties": false, "required": ["classification", "digest"], "properties": { "classification": { "enum": ["workspace_root", "workspace_relative"] }, "digest": { "$ref": "#/$defs/digest" } } },
        "status": { "enum": ["succeeded", "failed", "interrupted"] },
        "exit_code": { "type": ["integer", "null"] },
        "duration": { "type": "object", "additionalProperties": false, "required": ["status", "milliseconds"], "properties": { "status": { "enum": ["known", "unknown"] }, "milliseconds": { "type": ["integer", "null"], "minimum": 0 } } },
        "aggregated_output": { "type": "object", "additionalProperties": false, "required": ["bytes", "digest"], "properties": { "bytes": { "type": "integer", "minimum": 0 }, "digest": { "$ref": "#/$defs/digest" } } },
        "capture_source": { "const": "codex_exec_jsonl" },
        "evidence_level": { "const": "executed" },
        "bytes": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
