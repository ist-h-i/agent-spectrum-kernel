{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive ASK approved raw engineering result byte inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_path",
    "program",
    "plan_id",
    "plan_digest",
    "run_instance_id",
    "source_snapshot_digest",
    "adapter_track",
    "normalized_generation_id",
    "normalized_manifest_digest",
    "inventory",
    "source_revision",
    "manifest_digest"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "schema_path": { "const": "benchmarks/schemas/portfolio-engineering-result-source-manifest.schema.json" },
    "program": { "const": "adaptive_ask_portfolio_engineering_result_source_manifest" },
    "plan_id": { "type": "string", "pattern": "^plan-[a-f0-9]{64}$" },
    "plan_digest": { "$ref": "#/$defs/digest" },
    "run_instance_id": { "type": "string", "format": "uuid" },
    "source_snapshot_digest": { "$ref": "#/$defs/digest" },
    "adapter_track": { "enum": ["codex", "claude"] },
    "normalized_generation_id": { "type": "string", "pattern": "^snapshot-[a-f0-9]{64}$" },
    "normalized_manifest_digest": { "$ref": "#/$defs/digest" },
    "inventory": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/inventoryEntry" }
    },
    "source_revision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "manifest_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^(?!/)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)[^\\u0000]+$"
    },
    "inventoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "raw_byte_digest",
        "bytes",
        "engineering_result_id",
        "engineering_result_digest",
        "normalized_result_id",
        "normalized_result_digest",
        "case_id",
        "attempt",
        "condition",
        "repetition"
      ],
      "properties": {
        "path": { "$ref": "#/$defs/portablePath" },
        "raw_byte_digest": { "$ref": "#/$defs/digest" },
        "bytes": { "type": "integer", "minimum": 1, "maximum": 16777216 },
        "engineering_result_id": { "type": "string", "pattern": "^engineering-result-[a-f0-9]{32}$" },
        "engineering_result_digest": { "$ref": "#/$defs/digest" },
        "normalized_result_id": { "type": "string", "pattern": "^normalized-[a-f0-9]{32}$" },
        "normalized_result_digest": { "$ref": "#/$defs/digest" },
        "case_id": { "type": "string", "pattern": "^case-[a-f0-9]{16}-[a-f0-9]{16}$" },
        "attempt": { "type": "string", "pattern": "^[0-9]{4}$" },
        "condition": { "enum": ["plain", "kernel_only", "adaptive_ask", "full_ask"] },
        "repetition": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    }
  }
}
