{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ASK comparative benchmark normalized result",
  "type": "object",
  "required": ["schema_version", "checkpoint", "protocol", "runtime", "runs", "comparison", "limitations", "privacy"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "checkpoint": { "enum": ["B", "C"] },
    "protocol": { "type": "object" },
    "runtime": { "type": "object" },
    "runs": { "type": "array", "minItems": 1 },
    "comparison": { "type": "object" },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "privacy": { "type": "object" }
  }
}
