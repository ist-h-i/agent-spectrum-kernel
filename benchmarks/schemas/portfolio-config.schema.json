{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive ASK portfolio foundation config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "program",
    "protocol_path",
    "protocol_status",
    "conditions",
    "adapter_tracks",
    "pool_adapter_results",
    "fixture_root",
    "fixtures",
    "ordering",
    "execution_plan",
    "adaptive_selection",
    "privacy"
  ],
  "properties": {
    "$schema": { "const": "./schemas/portfolio-config.schema.json" },
    "schema_version": { "const": "3.0.0" },
    "program": { "const": "adaptive_ask_portfolio" },
    "protocol_path": { "type": "string", "minLength": 1 },
    "protocol_status": { "enum": ["foundation", "frozen"] },
    "conditions": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role", "instruction_surface"],
        "properties": {
          "id": { "enum": ["plain", "kernel_only", "adaptive_ask", "full_ask"] },
          "role": { "enum": ["context_baseline", "default_product", "primary_product", "diagnostic_maximum"] },
          "instruction_surface": { "type": "string", "minLength": 1 }
        }
      }
    },
    "adapter_tracks": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "runtime_status"],
        "properties": {
          "id": { "enum": ["codex", "claude"] },
          "runtime_status": { "enum": ["unverified", "available", "unavailable"] }
        }
      }
    },
    "pool_adapter_results": { "const": false },
    "fixture_root": { "type": "string", "minLength": 1 },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "suite",
          "task_class",
          "difficulty",
          "repetitions",
          "aggregate_eligible",
          "input_manifest_path",
          "input_manifest_sha256"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "suite": { "enum": ["mechanism_positive", "mechanism_negative", "practice_frequency", "high_impact", "calibration"] },
          "task_class": { "type": "string", "minLength": 1 },
          "difficulty": { "type": "string", "minLength": 1 },
          "repetitions": { "enum": [3, 5] },
          "aggregate_eligible": { "type": "boolean" },
          "input_manifest_path": { "type": "string", "minLength": 1 },
          "input_manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "ordering": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "condition_count"],
      "properties": {
        "strategy": { "const": "seeded_balanced_rotation" },
        "condition_count": { "const": 4 }
      }
    },
    "execution_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_path", "schema_version"],
      "properties": {
        "schema_path": { "const": "benchmarks/schemas/execution-plan.schema.json" },
        "schema_version": { "const": "1.0.0" }
      }
    },
    "adaptive_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_path", "must_precede_result", "digest_algorithm"],
      "properties": {
        "schema_path": { "type": "string", "minLength": 1 },
        "must_precede_result": { "const": true },
        "digest_algorithm": { "const": "sha256" }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["store_raw_prompts", "store_full_outputs", "store_full_event_streams", "store_full_source", "store_secrets_customer_or_personal_data"],
      "properties": {
        "store_raw_prompts": { "const": false },
        "store_full_outputs": { "const": false },
        "store_full_event_streams": { "const": false },
        "store_full_source": { "const": false },
        "store_secrets_customer_or_personal_data": { "const": false }
      }
    }
  }
}
