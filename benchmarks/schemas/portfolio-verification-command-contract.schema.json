{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive ASK public verification command contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "schema_path", "program", "fixture_id", "fixture_input_digest", "commands", "contract_digest"],
  "properties": {
    "schema_version": { "const": "1.1.0" },
    "schema_path": { "const": "benchmarks/schemas/portfolio-verification-command-contract.schema.json" },
    "program": { "const": "adaptive_ask_verification_command_contract" },
    "fixture_id": { "$ref": "#/$defs/token" },
    "fixture_input_digest": { "$ref": "#/$defs/digest" },
    "commands": { "type": "array", "minItems": 1, "maxItems": 32, "items": { "$ref": "#/$defs/command" } },
    "contract_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "token": { "type": "string", "minLength": 1, "maxLength": 96, "pattern": "^[a-z0-9][a-z0-9_-]*$" },
    "relativePath": { "type": "string", "minLength": 1, "maxLength": 240, "pattern": "^(?:\\.|(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)[A-Za-z0-9._/-]+)$" },
    "safeArg": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|/)\\.\\.(?:/|$))(?![A-Za-z_][A-Za-z0-9_]*=)[A-Za-z0-9._/:@%+,=-]+$" },
    "canonicalScript": { "type": "string", "minLength": 1, "maxLength": 4096, "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F\\u2028\\u2029]+$" },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_id", "purpose", "working_directory", "safe_argv", "execution_form", "shell_family", "shell_envelope", "canonical_script", "logical_command_digest", "rendered_event_command_digest", "requirement", "alternative_group_id", "timeout_ms", "command_contract_digest"],
      "properties": {
        "command_id": { "$ref": "#/$defs/token" },
        "purpose": { "enum": ["test", "validation", "build", "lint", "typecheck"] },
        "working_directory": { "$ref": "#/$defs/relativePath" },
        "safe_argv": { "oneOf": [{ "type": "array", "minItems": 1, "maxItems": 32, "items": { "$ref": "#/$defs/safeArg" } }, { "type": "null" }] },
        "execution_form": { "enum": ["direct_argv", "codex_shell_command"] },
        "shell_family": { "enum": ["posix_bash", null] },
        "shell_envelope": {
          "oneOf": [
            { "type": "object", "additionalProperties": false, "required": ["executable", "arguments"], "properties": { "executable": { "const": "/bin/bash" }, "arguments": { "const": ["-lc"] } } },
            { "type": "null" }
          ]
        },
        "canonical_script": { "oneOf": [{ "$ref": "#/$defs/canonicalScript" }, { "type": "null" }] },
        "logical_command_digest": { "$ref": "#/$defs/digest" },
        "rendered_event_command_digest": { "$ref": "#/$defs/digest" },
        "requirement": { "enum": ["required", "optional", "alternative"] },
        "alternative_group_id": { "oneOf": [{ "$ref": "#/$defs/token" }, { "type": "null" }] },
        "timeout_ms": { "type": ["integer", "null"], "minimum": 1, "maximum": 3600000 },
        "command_contract_digest": { "$ref": "#/$defs/digest" }
      },
      "allOf": [
        {
          "if": { "properties": { "execution_form": { "const": "direct_argv" } }, "required": ["execution_form"] },
          "then": { "properties": { "safe_argv": { "type": "array" }, "shell_family": { "type": "null" }, "shell_envelope": { "type": "null" }, "canonical_script": { "type": "null" } } },
          "else": { "properties": { "safe_argv": { "type": "null" }, "shell_family": { "const": "posix_bash" }, "shell_envelope": { "type": "object" }, "canonical_script": { "$ref": "#/$defs/canonicalScript" } } }
        },
        {
          "if": { "properties": { "requirement": { "const": "alternative" } }, "required": ["requirement"] },
          "then": { "properties": { "alternative_group_id": { "$ref": "#/$defs/token" } } },
          "else": { "properties": { "alternative_group_id": { "type": "null" } } }
        }
      ]
    }
  }
}
