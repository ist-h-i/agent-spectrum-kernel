{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive ASK portfolio effective adapter runtime identity",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "adapter", "runtime_config_sha256", "availability", "unavailable_reason", "executor", "model", "reasoning_effort", "sandbox_policy", "permission_policy", "case_timeout_ms", "thermal_state", "environment_allowlist", "environment_value_allowlist", "environment_snapshot", "executable", "effective_command", "effective_command_digest", "policy_enforcement", "availability_evidence", "command_evidence"],
  "properties": {
    "schema_version": { "const": "1.2.0" },
    "adapter": { "enum": ["codex", "claude"] },
    "runtime_config_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "availability": { "enum": ["available", "unavailable"] },
    "unavailable_reason": { "type": ["string", "null"], "minLength": 1, "maxLength": 160, "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F\\u2028\\u2029]+$" },
    "executor": { "type": "object", "additionalProperties": false, "required": ["id", "version"], "properties": { "id": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 } } },
    "model": { "type": "string", "minLength": 1 },
    "reasoning_effort": { "type": "string", "minLength": 1 },
    "sandbox_policy": { "type": "string", "minLength": 1 },
    "permission_policy": { "type": "string", "minLength": 1 },
    "case_timeout_ms": { "type": "integer", "minimum": 1 },
    "thermal_state": { "enum": ["cold", "warm"] },
    "environment_allowlist": { "type": "array", "maxItems": 64, "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" } },
    "environment_value_allowlist": { "type": "array", "maxItems": 64, "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" } },
    "environment_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest", "entries"],
      "properties": {
        "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "entries": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "present", "value", "digest", "bytes"],
            "properties": {
              "name": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" },
              "present": { "type": "boolean" },
              "value": { "type": ["string", "null"], "minLength": 1, "maxLength": 160, "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F\\u2028\\u2029]+$" },
              "digest": { "type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$" },
              "bytes": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "executable": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["executable_basename", "executable_sha256", "observed_version", "observed_version_digest", "observed_version_bytes"],
      "properties": {
        "executable_basename": { "type": "string", "minLength": 1 },
        "executable_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "observed_version": { "type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F\\u2028\\u2029]+$" },
        "observed_version_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "observed_version_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "effective_command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["argv", "task_transport", "output_transport", "output_schema_digest"],
      "properties": {
        "argv": { "type": "array", "items": { "type": "string" } },
        "task_transport": { "enum": ["stdin", "file", "none"] },
        "output_transport": { "enum": ["file", "none"] },
        "output_schema_digest": { "type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "effective_command_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "policy_enforcement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sandbox_policy", "permission_policy", "ephemeral", "user_config_isolated", "rules_isolated"],
      "properties": {
        "sandbox_policy": { "type": "string", "minLength": 1 },
        "permission_policy": { "type": "string", "minLength": 1 },
        "ephemeral": { "type": "boolean" },
        "user_config_isolated": { "type": "boolean" },
        "rules_isolated": { "type": "boolean" }
      }
    },
    "availability_evidence": { "enum": ["local_version_and_contract_probe", "declared_unavailable", "contract_probe_failed"] },
    "command_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["support", "evidence_level", "event_transport", "event_format_revision", "parser_revision", "contract_probe_evidence", "downgrade_reason", "shell_capability"],
      "properties": {
        "support": { "enum": ["supported", "unsupported", "unknown"] },
        "evidence_level": { "enum": ["executed", "unavailable"] },
        "event_transport": { "enum": ["codex_exec_jsonl", "none"] },
        "event_format_revision": { "type": ["string", "null"] },
        "parser_revision": { "type": ["string", "null"] },
        "contract_probe_evidence": { "enum": ["runtime_event_required", "declared_unavailable", "adapter_event_contract_not_implemented", "contract_probe_failed"] },
        "downgrade_reason": { "type": ["string", "null"], "minLength": 1 },
        "shell_capability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["support_status", "family", "executable", "envelope_arguments", "authority_source", "probe_status", "downgrade_reason"],
          "properties": {
            "support_status": { "enum": ["supported", "unsupported", "unknown"] },
            "family": { "enum": ["posix_bash", null] },
            "executable": { "enum": ["/bin/bash", null] },
            "envelope_arguments": { "oneOf": [{ "const": ["-lc"] }, { "type": "null" }] },
            "authority_source": { "enum": ["codex_exec_jsonl_command_rendering", "none"] },
            "probe_status": { "enum": ["runtime_event_required", "unsupported", "unknown"] },
            "downgrade_reason": { "type": ["string", "null"], "minLength": 1 }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "evidence_level": { "const": "executed" } }, "required": ["evidence_level"] },
          "then": { "properties": { "support": { "const": "supported" }, "event_transport": { "const": "codex_exec_jsonl" }, "event_format_revision": { "const": "codex-exec-jsonl-v1" }, "parser_revision": { "const": "1.3.0" }, "contract_probe_evidence": { "const": "runtime_event_required" } } },
          "else": { "properties": { "downgrade_reason": { "type": "string" } } }
        },
        {
          "if": { "properties": { "support": { "const": "supported" } }, "required": ["support"] },
          "then": {
            "properties": {
              "event_transport": { "const": "codex_exec_jsonl" },
              "event_format_revision": { "const": "codex-exec-jsonl-v1" },
              "parser_revision": { "const": "1.3.0" },
              "shell_capability": {
                "properties": {
                  "support_status": { "const": "supported" },
                  "family": { "const": "posix_bash" },
                  "executable": { "const": "/bin/bash" },
                  "envelope_arguments": { "const": ["-lc"] },
                  "authority_source": { "const": "codex_exec_jsonl_command_rendering" },
                  "probe_status": { "const": "runtime_event_required" }
                }
              }
            }
          },
          "else": { "properties": { "evidence_level": { "const": "unavailable" }, "event_transport": { "const": "none" }, "event_format_revision": { "type": "null" }, "parser_revision": { "type": "null" }, "shell_capability": { "properties": { "family": { "type": "null" }, "executable": { "type": "null" }, "envelope_arguments": { "type": "null" }, "authority_source": { "const": "none" }, "downgrade_reason": { "type": "string" } } } } }
        },
        {
          "if": { "properties": { "support": { "const": "unsupported" } }, "required": ["support"] },
          "then": { "properties": { "shell_capability": { "properties": { "support_status": { "const": "unsupported" }, "probe_status": { "const": "unsupported" } } } } },
          "else": {
            "if": { "properties": { "support": { "const": "unknown" } }, "required": ["support"] },
            "then": { "properties": { "shell_capability": { "properties": { "support_status": { "const": "unknown" }, "probe_status": { "const": "unknown" } } } } }
          }
        }
      ]
    }
  }
}
