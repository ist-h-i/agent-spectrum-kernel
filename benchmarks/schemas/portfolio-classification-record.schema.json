{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive ASK portfolio aggregate classification record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "classification_record_id",
    "classification_record_schema_path",
    "classification_record_path",
    "fixture_id",
    "fixture_role",
    "catalog_digest",
    "policy_manifest_digest",
    "pilot_result_digest",
    "supported_adapter_tracks",
    "ceiling_classification_result",
    "floor_classification_result",
    "classification_state",
    "reason_codes",
    "classification_revision",
    "classification_digest"
  ],
  "properties": {
    "classification_record_id": { "$ref": "#/$defs/token" },
    "classification_record_schema_path": { "const": "benchmarks/schemas/portfolio-classification-record.schema.json" },
    "classification_record_path": { "$ref": "#/$defs/path" },
    "fixture_id": { "$ref": "#/$defs/token" },
    "fixture_role": { "enum": ["primary", "calibration"] },
    "catalog_digest": { "$ref": "#/$defs/digest" },
    "policy_manifest_digest": { "$ref": "#/$defs/digest" },
    "pilot_result_digest": { "$ref": "#/$defs/digest" },
    "supported_adapter_tracks": { "$ref": "#/$defs/tokenArray" },
    "ceiling_classification_result": { "enum": ["candidate", "not_candidate", "unknown", "not_applicable"] },
    "floor_classification_result": { "enum": ["candidate", "not_candidate", "unknown", "not_applicable"] },
    "classification_state": { "enum": ["pending_measurement", "primary_eligible", "calibration_only", "redesign_required", "rejected", "insufficient_evidence"] },
    "reason_codes": { "$ref": "#/$defs/tokenArray" },
    "classification_revision": { "type": "integer", "minimum": 1 },
    "classification_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "token": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-z0-9][a-z0-9_-]*$" },
    "path": { "type": "string", "minLength": 1, "maxLength": 240, "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)[a-zA-Z0-9._/-]+$" },
    "tokenArray": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/token" } }
  }
}
