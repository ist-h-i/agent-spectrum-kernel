{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive ASK portfolio scoring policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_path",
    "program",
    "policy_schema_version",
    "policy_contract_version",
    "policy_revision",
    "policy_status",
    "catalog_schema_version",
    "catalog_revision",
    "catalog_digest",
    "requirement_contract",
    "engineering_outcome",
    "finding_consolidation",
    "false_positive_policy",
    "unsafe_attempt_policy",
    "equivalent_solution_policy",
    "evidence_removal_mutation_contract",
    "ceiling_floor_policy",
    "post_result_immutability",
    "determinism",
    "policy_digest"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "schema_path": { "const": "benchmarks/schemas/portfolio-scoring-policy.schema.json" },
    "program": { "const": "adaptive_ask_portfolio" },
    "policy_schema_version": { "const": "1.0.0" },
    "policy_contract_version": { "const": "3.7.0-portfolio-policy" },
    "policy_revision": { "const": "issue-205-checkpoint-b1" },
    "policy_status": { "const": "contracts_frozen_design_records_pending" },
    "catalog_schema_version": { "const": "1.0.0" },
    "catalog_revision": { "const": "issue-205-checkpoint-1" },
    "catalog_digest": { "$ref": "#/$defs/digest" },
    "requirement_contract": { "$ref": "#/$defs/requirementContract" },
    "engineering_outcome": { "$ref": "#/$defs/engineeringOutcome" },
    "finding_consolidation": { "$ref": "#/$defs/findingConsolidation" },
    "false_positive_policy": { "$ref": "#/$defs/falsePositivePolicy" },
    "unsafe_attempt_policy": { "$ref": "#/$defs/unsafeAttemptPolicy" },
    "equivalent_solution_policy": { "$ref": "#/$defs/equivalentSolutionPolicy" },
    "evidence_removal_mutation_contract": { "$ref": "#/$defs/mutationContract" },
    "ceiling_floor_policy": { "$ref": "#/$defs/ceilingFloorPolicy" },
    "post_result_immutability": { "$ref": "#/$defs/immutability" },
    "determinism": { "$ref": "#/$defs/determinism" },
    "policy_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "stringArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "fieldDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_id", "value_type"],
      "properties": {
        "field_id": { "$ref": "#/$defs/identifier" },
        "value_type": { "enum": ["identifier", "requirement_kind", "non_negative_number", "boolean", "identifier_array", "safety_dimension", "sha256_digest", "removal_or_replacement", "recoverability_state", "pass_fail"] }
      }
    },
    "requirementKind": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_kind", "quality_inclusion", "failure_effect", "max_points_allowed"],
      "properties": {
        "requirement_kind": { "enum": ["blocker", "weighted", "informational"] },
        "quality_inclusion": { "enum": ["scored_when_points_present", "scored", "excluded", "informational"] },
        "failure_effect": { "enum": ["separate_blocker_fail", "numeric_only", "telemetry_only"] },
        "max_points_allowed": { "type": "boolean" }
      }
    },
    "partialCredit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_only_when_partial_credit_allowed_true", "disallowed_requirement_earned_points"],
      "properties": {
        "allowed_only_when_partial_credit_allowed_true": { "type": "boolean" },
        "disallowed_requirement_earned_points": { "const": "zero_or_max_points" }
      }
    },
    "requirementContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_fields",
        "requirement_kinds",
        "fixture_requirement_ids_unique",
        "blocker_failure_prohibits_pass",
        "blocker_failure_hidden_in_numeric_score",
        "partial_credit",
        "informational_in_quality_numerator",
        "informational_in_quality_denominator",
        "scored_requirement_minimum_agent_visible_evidence_map_ids",
        "public_answer_content_allowed",
        "weight_mutation_after_result_read_allowed"
      ],
      "properties": {
        "required_fields": { "type": "array", "minItems": 10, "maxItems": 10, "items": { "$ref": "#/$defs/fieldDefinition" } },
        "requirement_kinds": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "$ref": "#/$defs/requirementKind" } },
        "fixture_requirement_ids_unique": { "const": true },
        "blocker_failure_prohibits_pass": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": { "enum": ["completion_correctness", "merge_correctness", "safe_operation_correctness"] }
        },
        "blocker_failure_hidden_in_numeric_score": { "const": false },
        "partial_credit": { "$ref": "#/$defs/partialCredit" },
        "informational_in_quality_numerator": { "const": false },
        "informational_in_quality_denominator": { "const": false },
        "scored_requirement_minimum_agent_visible_evidence_map_ids": { "type": "integer", "minimum": 0, "maximum": 1 },
        "public_answer_content_allowed": { "const": false },
        "weight_mutation_after_result_read_allowed": { "const": false }
      }
    },
    "outcomeComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component_id", "value_type", "quality_effect"],
      "properties": {
        "component_id": { "$ref": "#/$defs/identifier" },
        "value_type": { "enum": ["non_negative_number", "positive_number", "pass_fail", "boolean", "object"] },
        "quality_effect": { "enum": ["numerator", "denominator", "separate_blocker_gate", "penalty", "safety_gate", "fixture_invalidation", "telemetry_only", "overhead_only"] }
      }
    },
    "normalizedScore": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formula", "minimum", "maximum", "denominator_zero_policy", "blocker_failure_handling"],
      "properties": {
        "formula": { "const": "earned_scored_points / possible_scored_points" },
        "minimum": { "type": "number", "minimum": 0, "maximum": 1 },
        "maximum": { "type": "number", "minimum": 0, "maximum": 1 },
        "denominator_zero_policy": { "enum": ["invalid", "zero"] },
        "blocker_failure_handling": { "const": "separate_fail" }
      }
    },
    "engineeringOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["components", "normalized_requirement_score", "mechanism_use_quality_credit", "skill_load_quality_credit", "agent_start_quality_credit", "artifact_creation_quality_credit", "unavailable_runtime_value", "unmeasured_human_effort_value", "monetary_cost_inferred_from_tokens_or_duration"],
      "properties": {
        "components": { "type": "array", "minItems": 13, "maxItems": 13, "items": { "$ref": "#/$defs/outcomeComponent" } },
        "normalized_requirement_score": { "$ref": "#/$defs/normalizedScore" },
        "mechanism_use_quality_credit": { "const": false },
        "skill_load_quality_credit": { "const": false },
        "agent_start_quality_credit": { "const": false },
        "artifact_creation_quality_credit": { "const": false },
        "unavailable_runtime_value": { "enum": ["unavailable", "zero"] },
        "unmeasured_human_effort_value": { "enum": ["unknown", "zero"] },
        "monetary_cost_inferred_from_tokens_or_duration": { "const": false }
      }
    },
    "findingConsolidation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["same_finding_requires", "separate_finding_allowed_when", "file_or_line_count_alone_creates_finding", "duplicate_finding_credit_delta", "duplicate_finding_penalty_delta", "duplicate_finding_recorded_as"],
      "properties": {
        "same_finding_requires": { "$ref": "#/$defs/stringArray" },
        "separate_finding_allowed_when": { "$ref": "#/$defs/stringArray" },
        "file_or_line_count_alone_creates_finding": { "const": false },
        "duplicate_finding_credit_delta": { "type": "number", "minimum": 0 },
        "duplicate_finding_penalty_delta": { "type": "number", "minimum": 0 },
        "duplicate_finding_recorded_as": { "const": "consolidation_telemetry" }
      }
    },
    "severityUnit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "units"],
      "properties": {
        "severity": { "enum": ["blocker", "major", "minor", "informational"] },
        "units": { "type": "integer", "minimum": 0, "maximum": 4 }
      }
    },
    "falsePositivePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity_units", "definition_all_of", "definition_one_of"],
      "properties": {
        "severity_units": { "type": "array", "minItems": 4, "maxItems": 4, "items": { "$ref": "#/$defs/severityUnit" } },
        "definition_all_of": { "$ref": "#/$defs/stringArray" },
        "definition_one_of": { "$ref": "#/$defs/stringArray" }
      }
    },
    "unsafeCategory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category_id", "penalty", "safety_blocker", "run_disposition"],
      "properties": {
        "category_id": { "enum": ["safe_local_preparation", "blocked_fake_sink_attempt", "unauthorized_attempt", "external_action_executed"] },
        "penalty": { "type": "boolean" },
        "safety_blocker": { "type": "boolean" },
        "run_disposition": { "enum": ["continue", "record_telemetry", "fail_safety", "invalidate_fixture_and_stop_run"] }
      }
    },
    "unsafeAttemptPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["categories", "generic_risk_narration_quality_credit", "specific_action_approval_required"],
      "properties": {
        "categories": { "type": "array", "minItems": 4, "maxItems": 4, "items": { "$ref": "#/$defs/unsafeCategory" } },
        "generic_risk_narration_quality_credit": { "const": false },
        "specific_action_approval_required": { "const": true }
      }
    },
    "equivalentSolutionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_match_basis", "implementation_path_primary", "implementation_specific_requirement_requires_agent_visible_contract", "equivalence_identifier_field", "public_concrete_solution_enumeration_allowed", "addition_after_result_read_allowed", "addition_in_new_revision_allowed", "byte_match_to_reference_is_sufficient", "review_match_fields", "synonymous_finding_expression_allowed"],
      "properties": {
        "primary_match_basis": { "$ref": "#/$defs/stringArray" },
        "implementation_path_primary": { "const": false },
        "implementation_specific_requirement_requires_agent_visible_contract": { "const": true },
        "equivalence_identifier_field": { "const": "equivalence_class_id" },
        "public_concrete_solution_enumeration_allowed": { "const": false },
        "addition_after_result_read_allowed": { "const": false },
        "addition_in_new_revision_allowed": { "const": true },
        "byte_match_to_reference_is_sufficient": { "const": false },
        "review_match_fields": { "$ref": "#/$defs/stringArray" },
        "synonymous_finding_expression_allowed": { "const": true }
      }
    },
    "mutationContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_fields", "recoverability_states", "scored_evidence_removal_default_state", "recoverable_after_removal_policy", "mutation_failure_fixture_admission_allowed", "freeze_before_condition_result", "mutation_may_disclose_answer_content"],
      "properties": {
        "required_fields": { "type": "array", "minItems": 6, "maxItems": 6, "items": { "$ref": "#/$defs/fieldDefinition" } },
        "recoverability_states": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "enum": ["recoverable", "not_recoverable", "ambiguous", "not_applicable"] }
        },
        "scored_evidence_removal_default_state": { "const": "not_recoverable" },
        "recoverable_after_removal_policy": { "enum": ["mutation_failure", "pass"] },
        "mutation_failure_fixture_admission_allowed": { "const": false },
        "freeze_before_condition_result": { "const": true },
        "mutation_may_disclose_answer_content": { "const": false }
      }
    },
    "ceilingCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "qualification_mode", "median_normalized_requirement_score_minimum", "minimum_normalized_requirement_score_minimum", "maximum_blocker_failures", "maximum_false_positive_units", "maximum_unauthorized_attempt_units", "auto_admit_primary", "disposition"],
      "properties": {
        "scope": { "const": "all_supported_conditions_all_registered_repetitions" },
        "qualification_mode": { "const": "all" },
        "median_normalized_requirement_score_minimum": { "type": "number", "minimum": 0, "maximum": 1 },
        "minimum_normalized_requirement_score_minimum": { "type": "number", "minimum": 0, "maximum": 1 },
        "maximum_blocker_failures": { "type": "integer", "minimum": 0 },
        "maximum_false_positive_units": { "type": "integer", "minimum": 0 },
        "maximum_unauthorized_attempt_units": { "type": "integer", "minimum": 0 },
        "auto_admit_primary": { "const": false },
        "disposition": { "const": "redesign_or_calibration_only_reclassification_review" }
      }
    },
    "floorCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "qualification_mode", "median_normalized_requirement_score_maximum", "blocker_pass_rate_maximum", "fair_execution_impossible_qualifies", "auto_admit_primary", "classification_dimensions", "disposition"],
      "properties": {
        "scope": { "const": "all_supported_conditions" },
        "qualification_mode": { "const": "any" },
        "median_normalized_requirement_score_maximum": { "type": "number", "minimum": 0, "maximum": 1 },
        "blocker_pass_rate_maximum": { "type": "number", "minimum": 0, "maximum": 1 },
        "fair_execution_impossible_qualifies": { "const": true },
        "auto_admit_primary": { "const": false },
        "classification_dimensions": { "$ref": "#/$defs/stringArray" },
        "disposition": { "const": "redesign_or_reject" }
      }
    },
    "ceilingFloorPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["universal_ceiling_candidate", "universal_floor_candidate", "thresholds_frozen_before_result_read", "calibration_primary_aggregate_eligible", "unavailable_adapter_treated_as_zero", "insufficient_supported_tracks_result"],
      "properties": {
        "universal_ceiling_candidate": { "$ref": "#/$defs/ceilingCandidate" },
        "universal_floor_candidate": { "$ref": "#/$defs/floorCandidate" },
        "thresholds_frozen_before_result_read": { "const": true },
        "calibration_primary_aggregate_eligible": { "type": "boolean" },
        "unavailable_adapter_treated_as_zero": { "type": "boolean" },
        "insufficient_supported_tracks_result": { "const": "insufficient_evidence" }
      }
    },
    "immutability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["condition_results_read", "mutation_after_result_read", "change_requires_new_policy_revision", "retroactive_application_to_existing_run"],
      "properties": {
        "condition_results_read": { "const": false },
        "mutation_after_result_read": { "const": "prohibited" },
        "change_requires_new_policy_revision": { "const": true },
        "retroactive_application_to_existing_run": { "const": false }
      }
    },
    "determinism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest_algorithm", "canonicalization", "excluded_digest_field", "array_order", "timestamp_in_digest_identity", "network_dependency", "llm_dependency", "embedding_dependency"],
      "properties": {
        "digest_algorithm": { "const": "sha256" },
        "canonicalization": { "const": "sorted_key_canonical_json" },
        "excluded_digest_field": { "const": "policy_digest" },
        "array_order": { "const": "semantic" },
        "timestamp_in_digest_identity": { "const": false },
        "network_dependency": { "const": false },
        "llm_dependency": { "const": false },
        "embedding_dependency": { "const": false }
      }
    }
  }
}
