{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive ASK portfolio runtime configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "adapter",
    "availability",
    "unavailable_reason",
    "expected_executable_version",
    "model",
    "reasoning_effort",
    "case_timeout_ms",
    "sandbox_policy",
    "permission_policy",
    "executor",
    "environment_allowlist",
    "environment_value_allowlist",
    "thermal_state",
    "claude_cli",
    "command_evidence"
  ],
  "properties": {
    "schema_version": { "const": "1.1.0" },
    "adapter": { "enum": ["codex", "claude"] },
    "availability": { "enum": ["available", "unavailable"] },
    "unavailable_reason": { "type": ["string", "null"], "minLength": 1, "maxLength": 160, "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F\\u2028\\u2029]+$" },
    "expected_executable_version": { "type": ["string", "null"], "minLength": 1, "maxLength": 160, "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F\\u2028\\u2029]+$" },
    "model": { "type": "string", "minLength": 1 },
    "reasoning_effort": { "type": "string", "minLength": 1 },
    "case_timeout_ms": { "type": "integer", "minimum": 1 },
    "sandbox_policy": { "type": "string", "minLength": 1 },
    "permission_policy": { "type": "string", "minLength": 1 },
    "executor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "environment_allowlist": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" }
    },
    "environment_value_allowlist": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" }
    },
    "thermal_state": { "enum": ["cold", "warm"] },
    "claude_cli": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["help_marker", "command", "sandbox_argument", "permission_argument"],
      "properties": {
        "help_marker": { "type": "string", "minLength": 1 },
        "sandbox_argument": { "type": "string", "pattern": "^--[a-z0-9-]+$" },
        "permission_argument": { "type": "string", "pattern": "^--[a-z0-9-]+$" },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "command_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capture_required", "support", "event_transport", "event_format_revision", "parser_revision"],
      "properties": {
        "capture_required": { "const": true },
        "support": { "enum": ["supported", "unsupported", "unknown"] },
        "event_transport": { "enum": ["codex_exec_jsonl", "none"] },
        "event_format_revision": { "type": ["string", "null"] },
        "parser_revision": { "type": ["string", "null"] }
      }
    }
  }
}
