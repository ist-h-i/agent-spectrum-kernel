{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive ASK portfolio runtime configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "adapter",
    "availability",
    "unavailable_reason",
    "expected_executable_version",
    "model",
    "reasoning_effort",
    "case_timeout_ms",
    "sandbox_policy",
    "permission_policy",
    "executor",
    "environment_allowlist",
    "environment_value_allowlist",
    "thermal_state",
    "claude_cli",
    "command_evidence"
  ],
  "properties": {
    "schema_version": { "const": "1.2.0" },
    "adapter": { "enum": ["codex", "claude"] },
    "availability": { "enum": ["available", "unavailable"] },
    "unavailable_reason": { "type": ["string", "null"], "minLength": 1, "maxLength": 160, "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F\\u2028\\u2029]+$" },
    "expected_executable_version": { "type": ["string", "null"], "minLength": 1, "maxLength": 160, "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F\\u2028\\u2029]+$" },
    "model": { "type": "string", "minLength": 1 },
    "reasoning_effort": { "type": "string", "minLength": 1 },
    "case_timeout_ms": { "type": "integer", "minimum": 1 },
    "sandbox_policy": { "type": "string", "minLength": 1 },
    "permission_policy": { "type": "string", "minLength": 1 },
    "executor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "environment_allowlist": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" }
    },
    "environment_value_allowlist": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" }
    },
    "thermal_state": { "enum": ["cold", "warm"] },
    "claude_cli": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["help_marker", "command", "sandbox_argument", "permission_argument"],
      "properties": {
        "help_marker": { "type": "string", "minLength": 1 },
        "sandbox_argument": { "type": "string", "pattern": "^--[a-z0-9-]+$" },
        "permission_argument": { "type": "string", "pattern": "^--[a-z0-9-]+$" },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "command_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capture_required", "support", "event_transport", "event_format_revision", "parser_revision", "shell_capability"],
      "properties": {
        "capture_required": { "const": true },
        "support": { "enum": ["supported", "unsupported", "unknown"] },
        "event_transport": { "enum": ["codex_exec_jsonl", "none"] },
        "event_format_revision": { "type": ["string", "null"] },
        "parser_revision": { "type": ["string", "null"] },
        "shell_capability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["support_status", "family", "executable", "envelope_arguments", "authority_source", "probe_status", "downgrade_reason"],
          "properties": {
            "support_status": { "enum": ["supported", "unsupported", "unknown"] },
            "family": { "enum": ["posix_bash", null] },
            "executable": { "enum": ["/bin/bash", null] },
            "envelope_arguments": { "oneOf": [{ "const": ["-lc"] }, { "type": "null" }] },
            "authority_source": { "enum": ["codex_exec_jsonl_command_rendering", "none"] },
            "probe_status": { "enum": ["runtime_event_required", "unsupported", "unknown"] },
            "downgrade_reason": { "type": ["string", "null"], "minLength": 1, "maxLength": 160, "pattern": "^[a-z0-9][a-z0-9_.:-]*$" }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "command_evidence": { "properties": { "support": { "const": "supported" } }, "required": ["support"] } }, "required": ["command_evidence"] },
      "then": { "properties": { "command_evidence": { "properties": { "event_transport": { "const": "codex_exec_jsonl" }, "event_format_revision": { "const": "codex-exec-jsonl-v1" }, "parser_revision": { "const": "1.3.0" }, "shell_capability": { "properties": { "support_status": { "const": "supported" }, "family": { "const": "posix_bash" }, "executable": { "const": "/bin/bash" }, "envelope_arguments": { "const": ["-lc"] }, "authority_source": { "const": "codex_exec_jsonl_command_rendering" }, "probe_status": { "const": "runtime_event_required" }, "downgrade_reason": { "type": "null" } } } } } } },
      "else": { "properties": { "command_evidence": { "properties": { "event_transport": { "const": "none" }, "event_format_revision": { "type": "null" }, "parser_revision": { "type": "null" }, "shell_capability": { "properties": { "family": { "type": "null" }, "executable": { "type": "null" }, "envelope_arguments": { "type": "null" }, "authority_source": { "const": "none" }, "downgrade_reason": { "type": "string" } } } } } } }
    },
    {
      "if": { "properties": { "command_evidence": { "properties": { "support": { "const": "unsupported" } }, "required": ["support"] } }, "required": ["command_evidence"] },
      "then": { "properties": { "command_evidence": { "properties": { "shell_capability": { "properties": { "support_status": { "const": "unsupported" }, "probe_status": { "const": "unsupported" } } } } } } },
      "else": { "properties": { "command_evidence": { "properties": { "shell_capability": { "properties": { "support_status": { "enum": ["supported", "unknown"] }, "probe_status": { "enum": ["runtime_event_required", "unknown"] } } } } } } }
    }
  ]
}
