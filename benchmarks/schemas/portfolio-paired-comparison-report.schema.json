{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive ASK paired per-fixture condition comparison report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "schema_path", "program", "authority", "comparison_view_definitions", "fixture_comparisons", "boundaries", "paired_comparison_report_id", "paired_comparison_report_digest"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "schema_path": { "const": "benchmarks/schemas/portfolio-paired-comparison-report.schema.json" },
    "program": { "const": "adaptive_ask_portfolio_paired_comparison_report" },
    "authority": { "$ref": "#/$defs/authority" },
    "comparison_view_definitions": { "type": "array", "minItems": 3, "maxItems": 3, "uniqueItems": true, "items": { "$ref": "#/$defs/viewDefinition" } },
    "fixture_comparisons": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/fixtureComparison" } },
    "boundaries": { "$ref": "#/$defs/boundaries" },
    "paired_comparison_report_id": { "type": "string", "pattern": "^paired-comparison-report-[a-f0-9]{32}$" },
    "paired_comparison_report_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "token": { "type": "string", "minLength": 1, "maxLength": 160 },
    "count": { "type": "integer", "minimum": 0 },
    "signedCount": { "type": "integer" },
    "portablePath": { "type": "string", "minLength": 1, "maxLength": 240, "pattern": "^(?!/)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)[^\\u0000]+$" },
    "condition": { "enum": ["plain", "kernel_only", "adaptive_ask", "full_ask"] },
    "viewDefinition": {
      "type": "object", "additionalProperties": false,
      "required": ["view_id", "comparison_condition", "baseline_condition", "view_role"],
      "properties": {
        "view_id": { "enum": ["kernel_vs_plain", "adaptive_vs_kernel", "full_vs_kernel_diagnostic"] },
        "comparison_condition": { "$ref": "#/$defs/condition" },
        "baseline_condition": { "$ref": "#/$defs/condition" },
        "view_role": { "enum": ["primary_product_hypothesis", "diagnostic_only"] }
      }
    },
    "authority": {
      "type": "object", "additionalProperties": false,
      "required": ["repetition_report_id", "repetition_report_digest", "result_set_id", "result_set_digest", "source_manifest_raw_byte_digest", "source_manifest_digest", "normalized_generation_id", "normalized_manifest_digest", "source_snapshot_digest", "plan_id", "plan_digest", "run_instance_id", "source_revision", "adapter_track", "scoring_policy_revision", "scoring_policy_digest"],
      "properties": {
        "repetition_report_id": { "type": "string", "pattern": "^repetition-report-[a-f0-9]{32}$" },
        "repetition_report_digest": { "$ref": "#/$defs/digest" },
        "result_set_id": { "type": "string", "pattern": "^engineering-result-set-[a-f0-9]{32}$" },
        "result_set_digest": { "$ref": "#/$defs/digest" },
        "source_manifest_raw_byte_digest": { "$ref": "#/$defs/digest" },
        "source_manifest_digest": { "$ref": "#/$defs/digest" },
        "normalized_generation_id": { "type": "string", "pattern": "^snapshot-[a-f0-9]{64}$" },
        "normalized_manifest_digest": { "$ref": "#/$defs/digest" },
        "source_snapshot_digest": { "$ref": "#/$defs/digest" },
        "plan_id": { "type": "string", "pattern": "^plan-[a-f0-9]{64}$" },
        "plan_digest": { "$ref": "#/$defs/digest" },
        "run_instance_id": { "type": "string", "format": "uuid" },
        "source_revision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "adapter_track": { "enum": ["codex", "claude"] },
        "scoring_policy_revision": { "const": "issue-205-checkpoint-b1-r3" },
        "scoring_policy_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "fixtureComparison": {
      "type": "object", "additionalProperties": false,
      "required": ["fixture_id", "fixture_input_digest", "suite", "task_class", "expected_repetition_count", "comparison_views"],
      "properties": {
        "fixture_id": { "$ref": "#/$defs/token" },
        "fixture_input_digest": { "$ref": "#/$defs/digest" },
        "suite": { "enum": ["mechanism_positive", "mechanism_negative", "practice_frequency", "high_impact", "calibration"] },
        "task_class": { "$ref": "#/$defs/token" },
        "expected_repetition_count": { "enum": [3, 5] },
        "comparison_views": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "$ref": "#/$defs/comparisonView" } }
      }
    },
    "comparisonView": {
      "type": "object", "additionalProperties": false,
      "required": ["view_id", "comparison_condition", "baseline_condition", "view_role", "structural_pairing_status", "pair_count", "pairs", "quality_delta_distribution", "overhead_delta_distributions", "blocker_transition_counts", "safety_transition_counts"],
      "properties": {
        "view_id": { "enum": ["kernel_vs_plain", "adaptive_vs_kernel", "full_vs_kernel_diagnostic"] },
        "comparison_condition": { "$ref": "#/$defs/condition" },
        "baseline_condition": { "$ref": "#/$defs/condition" },
        "view_role": { "enum": ["primary_product_hypothesis", "diagnostic_only"] },
        "structural_pairing_status": { "const": "complete" },
        "pair_count": { "enum": [3, 5] },
        "pairs": { "type": "array", "minItems": 3, "maxItems": 5, "items": { "$ref": "#/$defs/pair" } },
        "quality_delta_distribution": { "$ref": "#/$defs/distribution" },
        "overhead_delta_distributions": { "$ref": "#/$defs/overheadDistributions" },
        "blocker_transition_counts": { "$ref": "#/$defs/blockerTransitions" },
        "safety_transition_counts": { "$ref": "#/$defs/safetyTransitions" }
      }
    },
    "pair": {
      "type": "object", "additionalProperties": false,
      "required": ["repetition", "baseline", "comparison", "status_pair", "quality_delta", "overhead_deltas", "raw_categorical_deltas"],
      "properties": {
        "repetition": { "type": "integer", "minimum": 1, "maximum": 5 },
        "baseline": { "$ref": "#/$defs/pairSource" },
        "comparison": { "$ref": "#/$defs/pairSource" },
        "status_pair": { "$ref": "#/$defs/statusPair" },
        "quality_delta": { "$ref": "#/$defs/qualityDelta" },
        "overhead_deltas": { "$ref": "#/$defs/overheadDeltas" },
        "raw_categorical_deltas": { "$ref": "#/$defs/rawCategoricalDeltas" }
      }
    },
    "pairSource": {
      "type": "object", "additionalProperties": false,
      "required": ["repetition", "condition", "path", "raw_byte_digest", "bytes", "engineering_result_id", "engineering_result_digest", "normalized_result_id", "normalized_result_digest", "evaluation_id", "evaluation_digest", "fixture_id", "fixture_input_digest", "suite", "task_class", "adapter", "expected_repetition_count", "scoring_policy_digest", "requirement_record_digest", "scoring_input_freeze_manifest_digest", "normalized_outcome", "evaluation_status", "scoring_status", "scoring_reason", "blocker_gate_status", "safety_blocker_status", "normalized_requirement_score", "false_positive_raw_count", "false_positive_severity_counts", "scope_deviation_raw_count", "correctness_states", "unsafe_action_category_counts", "mechanisms", "overhead_telemetry"],
      "properties": {
        "repetition": { "type": "integer", "minimum": 1, "maximum": 5 },
        "condition": { "$ref": "#/$defs/condition" },
        "path": { "$ref": "#/$defs/portablePath" },
        "raw_byte_digest": { "$ref": "#/$defs/digest" },
        "bytes": { "type": "integer", "minimum": 1 },
        "engineering_result_id": { "type": "string", "pattern": "^engineering-result-[a-f0-9]{32}$" },
        "engineering_result_digest": { "$ref": "#/$defs/digest" },
        "normalized_result_id": { "type": "string", "pattern": "^normalized-[a-f0-9]{32}$" },
        "normalized_result_digest": { "$ref": "#/$defs/digest" },
        "evaluation_id": { "type": "string", "pattern": "^evaluation-[a-f0-9]{32}$" },
        "evaluation_digest": { "$ref": "#/$defs/digest" },
        "fixture_id": { "$ref": "#/$defs/token" },
        "fixture_input_digest": { "$ref": "#/$defs/digest" },
        "suite": { "enum": ["mechanism_positive", "mechanism_negative", "practice_frequency", "high_impact", "calibration"] },
        "task_class": { "$ref": "#/$defs/token" },
        "adapter": { "enum": ["codex", "claude"] },
        "expected_repetition_count": { "enum": [3, 5] },
        "scoring_policy_digest": { "$ref": "#/$defs/digest" },
        "requirement_record_digest": { "$ref": "#/$defs/digest" },
        "scoring_input_freeze_manifest_digest": { "$ref": "#/$defs/digest" },
        "normalized_outcome": { "enum": ["completed", "failed", "unavailable", "interrupted", "invalid"] },
        "evaluation_status": { "enum": ["completed", "invalid_input", "evaluator_unavailable", "evaluator_failed", "manual_review_required"] },
        "scoring_status": { "enum": ["complete", "not_scoring_ready"] },
        "scoring_reason": { "enum": ["completed_evaluation_scoring_ready", "evaluation_invalid_input", "evaluator_unavailable", "evaluator_failed", "manual_review_required", "normalized_execution_failed", "normalized_execution_unavailable", "normalized_execution_interrupted", "normalized_execution_invalid"] },
        "blocker_gate_status": { "enum": ["pass", "fail", "not_applicable", "not_scoring_ready"] },
        "safety_blocker_status": { "enum": ["pass", "fail", "unknown", "not_scoring_ready"] },
        "normalized_requirement_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "false_positive_raw_count": { "$ref": "#/$defs/count" },
        "false_positive_severity_counts": { "$ref": "#/$defs/severityCounts" },
        "scope_deviation_raw_count": { "$ref": "#/$defs/count" },
        "correctness_states": { "$ref": "#/$defs/correctnessStates" },
        "unsafe_action_category_counts": { "type": "array", "minItems": 4, "maxItems": 4, "items": { "$ref": "#/$defs/unsafeCategoryCount" } },
        "mechanisms": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/mechanism" } },
        "overhead_telemetry": { "$ref": "#/$defs/overheadTelemetry" }
      },
      "allOf": [{
        "if": { "properties": { "scoring_status": { "const": "complete" } }, "required": ["scoring_status"] },
        "then": { "properties": { "normalized_requirement_score": { "type": "number", "minimum": 0, "maximum": 1 } } },
        "else": { "properties": { "normalized_requirement_score": { "type": "null" } } }
      }]
    },
    "severityCounts": {
      "type": "object", "additionalProperties": false,
      "required": ["critical", "high", "medium", "low", "informational"],
      "properties": { "critical": { "$ref": "#/$defs/count" }, "high": { "$ref": "#/$defs/count" }, "medium": { "$ref": "#/$defs/count" }, "low": { "$ref": "#/$defs/count" }, "informational": { "$ref": "#/$defs/count" } }
    },
    "correctnessState": { "enum": ["pass", "fail", "mixed", "detected", "not_detected", "unknown", "unavailable", "not_applicable", "not_evaluated", "manual_review_required"] },
    "correctnessStates": {
      "type": "object", "additionalProperties": false,
      "required": ["decision_correctness", "verification_correctness", "evidence_correctness", "approval_correctness", "completion_claim_correctness", "under_processing", "over_processing", "quality", "safety"],
      "properties": {
        "decision_correctness": { "$ref": "#/$defs/correctnessState" }, "verification_correctness": { "$ref": "#/$defs/correctnessState" }, "evidence_correctness": { "$ref": "#/$defs/correctnessState" },
        "approval_correctness": { "$ref": "#/$defs/correctnessState" }, "completion_claim_correctness": { "$ref": "#/$defs/correctnessState" }, "under_processing": { "$ref": "#/$defs/correctnessState" },
        "over_processing": { "$ref": "#/$defs/correctnessState" }, "quality": { "$ref": "#/$defs/correctnessState" }, "safety": { "$ref": "#/$defs/correctnessState" }
      }
    },
    "unsafeCategoryCount": {
      "type": "object", "additionalProperties": false,
      "required": ["category_id", "attempted_count", "blocked_count", "unknown_count"],
      "properties": { "category_id": { "enum": ["safe_local_preparation", "blocked_fake_sink_attempt", "unauthorized_attempt", "external_action_executed"] }, "attempted_count": { "$ref": "#/$defs/count" }, "blocked_count": { "$ref": "#/$defs/count" }, "unknown_count": { "$ref": "#/$defs/count" } }
    },
    "mechanism": {
      "type": "object", "additionalProperties": false,
      "required": ["mechanism_id", "classification", "state"],
      "properties": { "mechanism_id": { "$ref": "#/$defs/token" }, "classification": { "enum": ["required", "unnecessary"] }, "state": { "enum": ["observed", "missing", "unnecessary", "unknown", "not_applicable"] } }
    },
    "metricEvidence": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["status", "value", "reason"], "properties": { "status": { "const": "known" }, "value": { "type": "number", "minimum": 0 }, "reason": { "const": "committed_runtime_evidence" } } },
        { "type": "object", "additionalProperties": false, "required": ["status", "value", "reason"], "properties": { "status": { "enum": ["unknown", "unavailable", "not_applicable"] }, "value": { "type": "null" }, "reason": { "type": "string", "minLength": 1, "maxLength": 160 } } }
      ]
    },
    "overheadTelemetry": {
      "type": "object", "additionalProperties": false,
      "required": ["duration_ms", "input_tokens", "output_tokens", "cached_tokens", "monetary_cost", "human_effort", "tool_call_count", "file_read_count", "final_output_bytes", "runtime_agent_count", "harness_spawned_secondary_agent_count", "subagent_activity", "capability_downgrade_count"],
      "properties": {
        "duration_ms": { "$ref": "#/$defs/metricEvidence" }, "input_tokens": { "$ref": "#/$defs/metricEvidence" }, "output_tokens": { "$ref": "#/$defs/metricEvidence" }, "cached_tokens": { "$ref": "#/$defs/metricEvidence" },
        "monetary_cost": { "$ref": "#/$defs/metricEvidence" }, "human_effort": { "$ref": "#/$defs/metricEvidence" }, "tool_call_count": { "$ref": "#/$defs/metricEvidence" }, "file_read_count": { "$ref": "#/$defs/metricEvidence" },
        "final_output_bytes": { "$ref": "#/$defs/metricEvidence" }, "runtime_agent_count": { "$ref": "#/$defs/metricEvidence" }, "harness_spawned_secondary_agent_count": { "$ref": "#/$defs/metricEvidence" },
        "subagent_activity": { "$ref": "#/$defs/metricEvidence" }, "capability_downgrade_count": { "$ref": "#/$defs/metricEvidence" }
      }
    },
    "statusPair": {
      "type": "object", "additionalProperties": false,
      "required": ["baseline_normalized_outcome", "comparison_normalized_outcome", "baseline_evaluation_status", "comparison_evaluation_status", "baseline_scoring_status", "comparison_scoring_status", "baseline_scoring_reason", "comparison_scoring_reason", "baseline_blocker_gate_status", "comparison_blocker_gate_status", "baseline_safety_blocker_status", "comparison_safety_blocker_status"],
      "properties": {
        "baseline_normalized_outcome": { "enum": ["completed", "failed", "unavailable", "interrupted", "invalid"] }, "comparison_normalized_outcome": { "enum": ["completed", "failed", "unavailable", "interrupted", "invalid"] },
        "baseline_evaluation_status": { "enum": ["completed", "invalid_input", "evaluator_unavailable", "evaluator_failed", "manual_review_required"] }, "comparison_evaluation_status": { "enum": ["completed", "invalid_input", "evaluator_unavailable", "evaluator_failed", "manual_review_required"] },
        "baseline_scoring_status": { "enum": ["complete", "not_scoring_ready"] }, "comparison_scoring_status": { "enum": ["complete", "not_scoring_ready"] },
        "baseline_scoring_reason": { "$ref": "#/$defs/scoringReason" }, "comparison_scoring_reason": { "$ref": "#/$defs/scoringReason" },
        "baseline_blocker_gate_status": { "enum": ["pass", "fail", "not_applicable", "not_scoring_ready"] }, "comparison_blocker_gate_status": { "enum": ["pass", "fail", "not_applicable", "not_scoring_ready"] },
        "baseline_safety_blocker_status": { "enum": ["pass", "fail", "unknown", "not_scoring_ready"] }, "comparison_safety_blocker_status": { "enum": ["pass", "fail", "unknown", "not_scoring_ready"] }
      }
    },
    "scoringReason": { "enum": ["completed_evaluation_scoring_ready", "evaluation_invalid_input", "evaluator_unavailable", "evaluator_failed", "manual_review_required", "normalized_execution_failed", "normalized_execution_unavailable", "normalized_execution_interrupted", "normalized_execution_invalid"] },
    "qualityDelta": {
      "type": "object", "additionalProperties": false,
      "required": ["baseline_normalized_requirement_score", "comparison_normalized_requirement_score", "delta_status", "normalized_requirement_score_delta"],
      "properties": {
        "baseline_normalized_requirement_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "comparison_normalized_requirement_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "delta_status": { "enum": ["complete", "insufficient_evidence"] },
        "normalized_requirement_score_delta": { "type": ["number", "null"], "minimum": -1, "maximum": 1 }
      }
    },
    "metricDelta": {
      "type": "object", "additionalProperties": false,
      "required": ["unit", "baseline", "comparison", "delta_status", "delta"],
      "properties": {
        "unit": { "enum": ["milliseconds", "tokens", "native_cost", "native_effort", "count", "bytes"] },
        "baseline": { "$ref": "#/$defs/metricEvidence" }, "comparison": { "$ref": "#/$defs/metricEvidence" },
        "delta_status": { "enum": ["complete", "insufficient_evidence"] }, "delta": { "type": ["number", "null"] }
      }
    },
    "overheadDeltas": {
      "type": "object", "additionalProperties": false,
      "required": ["duration_ms", "input_tokens", "output_tokens", "cached_tokens", "monetary_cost", "human_effort", "tool_call_count", "file_read_count", "final_output_bytes", "runtime_agent_count", "harness_spawned_secondary_agent_count", "subagent_activity", "capability_downgrade_count"],
      "properties": {
        "duration_ms": { "$ref": "#/$defs/metricDelta" }, "input_tokens": { "$ref": "#/$defs/metricDelta" }, "output_tokens": { "$ref": "#/$defs/metricDelta" }, "cached_tokens": { "$ref": "#/$defs/metricDelta" },
        "monetary_cost": { "$ref": "#/$defs/metricDelta" }, "human_effort": { "$ref": "#/$defs/metricDelta" }, "tool_call_count": { "$ref": "#/$defs/metricDelta" }, "file_read_count": { "$ref": "#/$defs/metricDelta" },
        "final_output_bytes": { "$ref": "#/$defs/metricDelta" }, "runtime_agent_count": { "$ref": "#/$defs/metricDelta" }, "harness_spawned_secondary_agent_count": { "$ref": "#/$defs/metricDelta" },
        "subagent_activity": { "$ref": "#/$defs/metricDelta" }, "capability_downgrade_count": { "$ref": "#/$defs/metricDelta" }
      }
    },
    "rawCountDelta": {
      "type": "object", "additionalProperties": false, "required": ["baseline", "comparison", "delta"],
      "properties": { "baseline": { "$ref": "#/$defs/count" }, "comparison": { "$ref": "#/$defs/count" }, "delta": { "$ref": "#/$defs/signedCount" } }
    },
    "severityCountDeltas": {
      "type": "object", "additionalProperties": false, "required": ["critical", "high", "medium", "low", "informational"],
      "properties": { "critical": { "$ref": "#/$defs/rawCountDelta" }, "high": { "$ref": "#/$defs/rawCountDelta" }, "medium": { "$ref": "#/$defs/rawCountDelta" }, "low": { "$ref": "#/$defs/rawCountDelta" }, "informational": { "$ref": "#/$defs/rawCountDelta" } }
    },
    "correctnessStatePair": { "type": "object", "additionalProperties": false, "required": ["baseline_state", "comparison_state"], "properties": { "baseline_state": { "$ref": "#/$defs/correctnessState" }, "comparison_state": { "$ref": "#/$defs/correctnessState" } } },
    "correctnessStatePairs": {
      "type": "object", "additionalProperties": false,
      "required": ["decision_correctness", "verification_correctness", "evidence_correctness", "approval_correctness", "completion_claim_correctness", "under_processing", "over_processing", "quality", "safety"],
      "properties": {
        "decision_correctness": { "$ref": "#/$defs/correctnessStatePair" }, "verification_correctness": { "$ref": "#/$defs/correctnessStatePair" }, "evidence_correctness": { "$ref": "#/$defs/correctnessStatePair" },
        "approval_correctness": { "$ref": "#/$defs/correctnessStatePair" }, "completion_claim_correctness": { "$ref": "#/$defs/correctnessStatePair" }, "under_processing": { "$ref": "#/$defs/correctnessStatePair" },
        "over_processing": { "$ref": "#/$defs/correctnessStatePair" }, "quality": { "$ref": "#/$defs/correctnessStatePair" }, "safety": { "$ref": "#/$defs/correctnessStatePair" }
      }
    },
    "unsafeCategoryDelta": {
      "type": "object", "additionalProperties": false,
      "required": ["category_id", "baseline_attempted_count", "comparison_attempted_count", "attempted_count_delta", "baseline_blocked_count", "comparison_blocked_count", "blocked_count_delta", "baseline_unknown_count", "comparison_unknown_count", "unknown_count_delta"],
      "properties": {
        "category_id": { "enum": ["safe_local_preparation", "blocked_fake_sink_attempt", "unauthorized_attempt", "external_action_executed"] },
        "baseline_attempted_count": { "$ref": "#/$defs/count" }, "comparison_attempted_count": { "$ref": "#/$defs/count" }, "attempted_count_delta": { "$ref": "#/$defs/signedCount" },
        "baseline_blocked_count": { "$ref": "#/$defs/count" }, "comparison_blocked_count": { "$ref": "#/$defs/count" }, "blocked_count_delta": { "$ref": "#/$defs/signedCount" },
        "baseline_unknown_count": { "$ref": "#/$defs/count" }, "comparison_unknown_count": { "$ref": "#/$defs/count" }, "unknown_count_delta": { "$ref": "#/$defs/signedCount" }
      }
    },
    "mechanismStatePair": {
      "type": "object", "additionalProperties": false,
      "required": ["mechanism_id", "classification", "baseline_state", "comparison_state", "quality_credit_applied"],
      "properties": { "mechanism_id": { "$ref": "#/$defs/token" }, "classification": { "enum": ["required", "unnecessary"] }, "baseline_state": { "enum": ["observed", "missing", "unnecessary", "unknown", "not_applicable"] }, "comparison_state": { "enum": ["observed", "missing", "unnecessary", "unknown", "not_applicable"] }, "quality_credit_applied": { "const": false } }
    },
    "rawCategoricalDeltas": {
      "type": "object", "additionalProperties": false,
      "required": ["false_positives", "scope_deviations", "correctness_state_pairs", "correctness_penalty_applied", "unsafe_action_category_deltas", "safety_scalar_calculated", "mechanism_state_pairs", "mechanism_quality_credit_applied"],
      "properties": {
        "false_positives": {
          "type": "object", "additionalProperties": false,
          "required": ["baseline_raw_count", "comparison_raw_count", "raw_count_delta", "severity_counts", "false_positive_unit_mapping_applied"],
          "properties": { "baseline_raw_count": { "$ref": "#/$defs/count" }, "comparison_raw_count": { "$ref": "#/$defs/count" }, "raw_count_delta": { "$ref": "#/$defs/signedCount" }, "severity_counts": { "$ref": "#/$defs/severityCountDeltas" }, "false_positive_unit_mapping_applied": { "const": false } }
        },
        "scope_deviations": { "type": "object", "additionalProperties": false, "required": ["baseline_count", "comparison_count", "count_delta"], "properties": { "baseline_count": { "$ref": "#/$defs/count" }, "comparison_count": { "$ref": "#/$defs/count" }, "count_delta": { "$ref": "#/$defs/signedCount" } } },
        "correctness_state_pairs": { "$ref": "#/$defs/correctnessStatePairs" },
        "correctness_penalty_applied": { "const": false },
        "unsafe_action_category_deltas": { "type": "array", "minItems": 4, "maxItems": 4, "items": { "$ref": "#/$defs/unsafeCategoryDelta" } },
        "safety_scalar_calculated": { "const": false },
        "mechanism_state_pairs": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/mechanismStatePair" } },
        "mechanism_quality_credit_applied": { "const": false }
      }
    },
    "distribution": {
      "type": "object", "additionalProperties": false,
