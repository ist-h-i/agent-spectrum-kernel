{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive ASK private evaluator bundle manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_path",
    "program",
    "evaluator_bundle_id",
    "evaluator_bundle_digest",
    "fixture_identity",
    "input_identity",
    "evaluator_revision",
    "generator",
    "independence",
    "review",
    "asset_inventory",
    "capabilities",
    "boundaries"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "schema_path": { "const": "benchmarks/schemas/private-evaluator-bundle.schema.json" },
    "program": { "const": "adaptive_ask_private_evaluator_bundle" },
    "evaluator_bundle_id": { "$ref": "#/$defs/bundleId" },
    "evaluator_bundle_digest": { "$ref": "#/$defs/digest" },
    "fixture_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture_id", "task_class", "suite"],
      "properties": {
        "fixture_id": { "$ref": "#/$defs/token" },
        "task_class": { "$ref": "#/$defs/token" },
        "suite": { "enum": ["mechanism_positive", "mechanism_negative", "practice_frequency", "high_impact", "calibration"] }
      }
    },
    "input_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture_input_digest"],
      "properties": {
        "fixture_input_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "evaluator_revision": { "$ref": "#/$defs/revision" },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "source_digest"],
      "properties": {
        "id": { "$ref": "#/$defs/token" },
        "version": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[0-9A-Za-z][0-9A-Za-z._-]*$" },
        "source_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "independence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement_digest", "generated_without_agent_output", "public_answer_sources_used", "measured_agent_access_allowed"],
      "properties": {
        "statement_digest": { "$ref": "#/$defs/digest" },
        "generated_without_agent_output": { "const": true },
        "public_answer_sources_used": { "const": false },
        "measured_agent_access_allowed": { "const": false }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_digest", "status", "reviewer_count"],
      "properties": {
        "record_digest": { "$ref": "#/$defs/digest" },
        "status": { "enum": ["pending", "approved", "changes_requested"] },
        "reviewer_count": { "type": "integer", "minimum": 1 }
      }
    },
    "asset_inventory": {
      "type": "array",
      "minItems": 1,
      "maxItems": 11,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/asset" }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["automated_evaluation", "manual_evaluation"],
      "properties": {
        "automated_evaluation": { "type": "boolean" },
        "manual_evaluation": { "type": "boolean" }
      }
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["private_evaluator_bundle", "public_repository_allowed", "public_ci_artifact_allowed", "contains_answer_bearing_content"],
      "properties": {
        "private_evaluator_bundle": { "const": true },
        "public_repository_allowed": { "const": false },
        "public_ci_artifact_allowed": { "const": false },
        "contains_answer_bearing_content": { "const": true }
      }
    }
  },
  "$defs": {
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "path", "sha256", "bytes", "media_type", "required"],
      "properties": {
        "role": {
          "enum": [
            "oracle",
            "rubric",
            "hidden_tests",
            "matchers",
            "equivalent_solution_rules",
            "false_positive_boundaries",
            "scope_boundaries",
            "unsafe_action_rules",
            "evidence_removal_mutations",
            "human_evaluation_instructions",
            "independence_provenance",
            "reference_outcome"
          ]
        },
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/digest" },
        "bytes": { "type": "integer", "minimum": 1 },
        "media_type": { "type": "string", "minLength": 1, "maxLength": 96, "pattern": "^[a-z0-9][a-z0-9.+-]*/[a-z0-9][a-z0-9.+-]*$" },
        "required": { "type": "boolean" }
      }
    },
    "bundleId": { "type": "string", "pattern": "^evaluator-[a-f0-9]{64}$" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "path": { "type": "string", "minLength": 1, "maxLength": 240, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!\\./).+$" },
    "revision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "token": { "type": "string", "minLength": 1, "maxLength": 96, "pattern": "^[a-z0-9][a-z0-9_-]*$" }
  }
}
