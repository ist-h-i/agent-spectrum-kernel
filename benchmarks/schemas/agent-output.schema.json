{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ASK benchmark agent output",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_type", "decision", "findings", "requirement_status", "verification_commands", "completion_claim", "route", "summary"],
  "properties": {
    "task_type": { "enum": ["review", "implementation"] },
    "decision": { "enum": ["approve", "approve_with_comments", "request_changes", "block", "insufficient_evidence", "not_applicable"] },
    "findings": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "file", "line", "summary", "evidence"],
        "properties": {
          "severity": { "enum": ["blocking", "major", "minor", "note"] },
          "file": { "type": "string", "maxLength": 512 },
          "line": { "type": ["integer", "null"], "minimum": 1 },
          "summary": { "type": "string", "maxLength": 1024 },
          "evidence": { "type": "string", "maxLength": 4096 }
        }
      }
    },
    "requirement_status": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requirement_id", "status", "evidence"],
        "properties": {
          "requirement_id": { "type": "string", "maxLength": 128 },
          "status": { "enum": ["satisfied", "not_satisfied", "unknown"] },
          "evidence": { "type": "string", "maxLength": 4096 }
        }
      }
    },
    "verification_commands": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "result"],
        "properties": {
          "command": { "type": "string", "maxLength": 2048 },
          "result": { "enum": ["passed", "failed", "not_run", "unknown"] }
        }
      }
    },
    "completion_claim": { "enum": ["complete", "incomplete", "insufficient_evidence", "not_applicable"] },
    "route": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["operating_mode", "primary_workflow", "evidence"],
      "properties": {
        "operating_mode": { "type": "string", "maxLength": 128 },
        "primary_workflow": { "type": "string", "maxLength": 128 },
        "evidence": { "type": "string", "maxLength": 4096 }
      }
    },
    "summary": { "type": "string", "maxLength": 4096 }
  }
}
