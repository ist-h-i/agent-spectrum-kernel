{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive ASK portfolio lineage policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_path",
    "program",
    "policy_schema_version",
    "policy_contract_version",
    "policy_revision",
    "policy_status",
    "catalog_schema_version",
    "catalog_revision",
    "catalog_digest",
    "source_policy",
    "lineage_record_contract",
    "frequency_bands",
    "impact_bands",
    "frequency_impact_independence",
    "post_result_immutability",
    "determinism",
    "policy_digest"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "schema_path": { "const": "benchmarks/schemas/portfolio-lineage-policy.schema.json" },
    "program": { "const": "adaptive_ask_portfolio" },
    "policy_schema_version": { "const": "1.0.0" },
    "policy_contract_version": { "const": "3.7.0-portfolio-policy" },
    "policy_revision": { "const": "issue-205-checkpoint-b1-r1" },
    "policy_status": { "const": "contracts_frozen_design_records_pending" },
    "catalog_schema_version": { "const": "1.0.0" },
    "catalog_revision": { "const": "issue-205-checkpoint-1" },
    "catalog_digest": { "$ref": "#/$defs/digest" },
    "source_policy": { "$ref": "#/$defs/sourcePolicy" },
    "lineage_record_contract": { "$ref": "#/$defs/lineageRecordContract" },
    "frequency_bands": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "$ref": "#/$defs/frequencyBand" }
    },
    "impact_bands": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "$ref": "#/$defs/impactBand" }
    },
    "frequency_impact_independence": { "$ref": "#/$defs/frequencyImpactIndependence" },
    "post_result_immutability": { "$ref": "#/$defs/immutability" },
    "determinism": { "$ref": "#/$defs/determinism" },
    "policy_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "sourcePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approved_source_types", "prohibited_source_types", "author_intuition_only_allowed", "raw_private_text_allowed", "issue_195_content_allowed", "measured_ask_outcome_allowed"],
      "properties": {
        "approved_source_types": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "enum": ["two_repository_occurrences", "incident_plus_review", "approved_anonymized_project_example", "documented_external_pattern", "author_intuition_only", "contaminated_issue_195_content"] }
        },
        "prohibited_source_types": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "uniqueItems": true,
          "items": { "enum": ["author_intuition_only", "customer_private_raw_text", "contaminated_issue_195_content", "measured_ask_outcome", "frequency_impact_conflation"] }
        },
        "author_intuition_only_allowed": { "type": "boolean" },
        "raw_private_text_allowed": { "const": false },
        "issue_195_content_allowed": { "type": "boolean" },
        "measured_ask_outcome_allowed": { "const": false }
      }
    },
    "fieldDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_id", "value_type"],
      "properties": {
        "field_id": { "$ref": "#/$defs/identifier" },
        "value_type": { "enum": ["identifier", "approved_source_type", "identifier_array", "frequency_band", "impact_band", "positive_integer", "sha256_digest"] }
      }
    },
    "lineageRecordContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_fields", "actual_assignment_in_policy_artifact"],
      "properties": {
        "required_fields": { "type": "array", "minItems": 12, "maxItems": 12, "items": { "$ref": "#/$defs/fieldDefinition" } },
        "actual_assignment_in_policy_artifact": { "const": false }
      }
    },
    "frequencyBand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["band_id", "minimum_occurrences_per_year", "maximum_occurrences_per_year", "cadence_evidence", "weight", "aggregate_eligible"],
      "properties": {
        "band_id": { "enum": ["high", "medium", "low", "unknown"] },
        "minimum_occurrences_per_year": { "type": ["integer", "null"], "minimum": 0 },
        "maximum_occurrences_per_year": { "type": ["integer", "null"], "minimum": 0 },
        "cadence_evidence": { "enum": ["monthly_or_more_frequent", "approximately_quarterly", "approved_evidence_of_real_occurrence", "insufficient_evidence"] },
        "weight": { "type": ["integer", "null"], "minimum": 1, "maximum": 4 },
        "aggregate_eligible": { "type": "boolean" }
      }
    },
    "impactBand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["band_id", "evidence_dimensions", "weight", "aggregate_eligible"],
      "properties": {
        "band_id": { "enum": ["high", "medium", "low", "unknown"] },
        "evidence_dimensions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["authorization", "safety", "data_integrity", "financial", "release_or_rollback", "multiple_components", "customer_impact", "clear_rework", "operational_burden", "localized", "reversible", "limited_engineering_cost", "insufficient_evidence"] }
        },
        "weight": { "type": ["integer", "null"], "minimum": 1, "maximum": 4 },
        "aggregate_eligible": { "type": "boolean" }
      }
    },
    "frequencyImpactIndependence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["separate_evidence_reference_fields_required", "separate_review_fields_required", "same_evidence_required", "frequency_may_substitute_for_impact", "impact_may_substitute_for_frequency"],
      "properties": {
        "separate_evidence_reference_fields_required": { "type": "boolean" },
        "separate_review_fields_required": { "type": "boolean" },
        "same_evidence_required": { "type": "boolean" },
        "frequency_may_substitute_for_impact": { "const": false },
        "impact_may_substitute_for_frequency": { "const": false }
      }
    },
    "immutability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["condition_results_read", "mutation_after_result_read", "change_requires_new_policy_revision", "retroactive_application_to_existing_run"],
      "properties": {
        "condition_results_read": { "const": false },
        "mutation_after_result_read": { "const": "prohibited" },
        "change_requires_new_policy_revision": { "const": true },
        "retroactive_application_to_existing_run": { "const": false }
      }
    },
    "determinism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest_algorithm", "canonicalization", "excluded_digest_field", "array_order", "timestamp_in_digest_identity", "network_dependency", "llm_dependency", "embedding_dependency"],
      "properties": {
        "digest_algorithm": { "const": "sha256" },
        "canonicalization": { "const": "sorted_key_canonical_json" },
        "excluded_digest_field": { "const": "policy_digest" },
        "array_order": { "const": "semantic" },
        "timestamp_in_digest_identity": { "const": false },
        "network_dependency": { "const": false },
        "llm_dependency": { "const": false },
        "embedding_dependency": { "const": false }
      }
    }
  }
}
