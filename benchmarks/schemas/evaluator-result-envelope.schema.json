{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive ASK evaluator result envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_path",
    "program",
    "scoring_input_freeze_manifest_source_digest",
    "scoring_input_freeze_manifest_digest",
    "catalog_digest",
    "policy_manifest_digest",
    "scoring_policy_digest",
    "admission_record_digest",
    "requirement_record_digest",
    "requirement_set_digest",
    "output_contract_digest",
    "evaluator_public_reference_digest",
    "normalized_result_id",
    "normalized_result_digest",
    "run_instance_id",
    "plan_id",
    "plan_digest",
    "fixture_id",
    "fixture_input_digest",
    "case_id",
    "attempt",
    "adapter",
    "condition",
    "repetition",
    "source_snapshot_digest",
    "evaluator_bundle_id",
    "evaluator_bundle_digest",
    "evaluator_revision",
    "evaluation_id",
    "evaluation_digest",
    "evaluation_status",
    "requirement_results",
    "quality",
    "safety",
    "findings",
    "false_positives",
    "scope_deviations",
    "decision_correctness",
    "verification_correctness",
    "evidence_correctness",
    "approval_correctness",
    "completion_claim_correctness",
    "under_processing",
    "over_processing",
    "required_mechanisms",
    "unnecessary_mechanisms",
    "unsafe_attempted_actions",
    "evaluator_notes_state",
    "privacy"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "schema_path": { "const": "benchmarks/schemas/evaluator-result-envelope.schema.json" },
    "program": { "const": "adaptive_ask_evaluator_result" },
    "scoring_input_freeze_manifest_source_digest": { "$ref": "#/$defs/digest" },
    "scoring_input_freeze_manifest_digest": { "$ref": "#/$defs/digest" },
    "catalog_digest": { "$ref": "#/$defs/digest" },
    "policy_manifest_digest": { "$ref": "#/$defs/digest" },
    "scoring_policy_digest": { "$ref": "#/$defs/digest" },
    "admission_record_digest": { "$ref": "#/$defs/digest" },
    "requirement_record_digest": { "$ref": "#/$defs/digest" },
    "requirement_set_digest": { "$ref": "#/$defs/digest" },
    "output_contract_digest": { "$ref": "#/$defs/digest" },
    "evaluator_public_reference_digest": { "$ref": "#/$defs/digest" },
    "normalized_result_id": { "type": "string", "pattern": "^normalized-[a-f0-9]{32}$" },
    "normalized_result_digest": { "$ref": "#/$defs/digest" },
    "run_instance_id": { "type": "string", "format": "uuid" },
    "plan_id": { "type": "string", "pattern": "^plan-[a-f0-9]{64}$" },
    "plan_digest": { "$ref": "#/$defs/digest" },
    "fixture_id": { "$ref": "#/$defs/token" },
    "fixture_input_digest": { "$ref": "#/$defs/digest" },
    "case_id": { "type": "string", "pattern": "^case-[a-f0-9]{16}-[a-f0-9]{16}$" },
    "attempt": { "type": "string", "pattern": "^[0-9]{4}$" },
    "adapter": { "enum": ["codex", "claude"] },
    "condition": { "enum": ["plain", "kernel_only", "adaptive_ask", "full_ask"] },
    "repetition": { "type": "integer", "minimum": 1, "maximum": 5 },
    "source_snapshot_digest": { "$ref": "#/$defs/digest" },
    "evaluator_bundle_id": { "type": "string", "pattern": "^evaluator-[a-f0-9]{64}$" },
    "evaluator_bundle_digest": { "$ref": "#/$defs/digest" },
    "evaluator_revision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "result_profile": { "$ref": "#/$defs/resultProfile" },
    "evaluation_id": { "type": "string", "pattern": "^evaluation-[a-f0-9]{32}$" },
    "evaluation_digest": { "$ref": "#/$defs/digest" },
    "evaluation_status": { "enum": ["completed", "invalid_input", "evaluator_unavailable", "evaluator_failed", "manual_review_required"] },
    "requirement_results": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/requirementResult" } },
    "classification": { "enum": ["correct_narrow_execution", "under_processing", "over_processing", "invalid_evidence"] },
    "quality": { "$ref": "#/$defs/observation" },
    "safety": { "$ref": "#/$defs/observation" },
    "findings": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/finding" } },
    "false_positives": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/finding" } },
    "scope_deviations": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/finding" } },
    "decision_correctness": { "$ref": "#/$defs/observation" },
    "verification_correctness": { "$ref": "#/$defs/observation" },
    "evidence_correctness": { "$ref": "#/$defs/observation" },
    "approval_correctness": { "$ref": "#/$defs/observation" },
    "completion_claim_correctness": { "$ref": "#/$defs/observation" },
    "under_processing": { "$ref": "#/$defs/observation" },
    "over_processing": { "$ref": "#/$defs/observation" },
    "required_mechanisms": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/mechanism" } },
    "unnecessary_mechanisms": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/mechanism" } },
    "unsafe_attempted_actions": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/unsafeAction" } },
    "evaluator_notes_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "digest", "bytes"],
      "properties": {
        "state": { "enum": ["not_recorded", "digested", "manual_review_required"] },
        "digest": { "type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$" },
        "bytes": { "type": ["integer", "null"], "minimum": 1 }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "oracle_content_stored",
        "rubric_content_stored",
        "hidden_test_content_stored",
        "matcher_content_stored",
        "reference_answer_stored",
        "raw_evaluator_prompt_stored",
        "private_path_stored",
        "secret_customer_or_personal_data_stored"
      ],
      "properties": {
        "oracle_content_stored": { "const": false },
        "rubric_content_stored": { "const": false },
        "hidden_test_content_stored": { "const": false },
        "matcher_content_stored": { "const": false },
        "reference_answer_stored": { "const": false },
        "raw_evaluator_prompt_stored": { "const": false },
        "private_path_stored": { "const": false },
        "secret_customer_or_personal_data_stored": { "const": false }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "token": { "type": "string", "minLength": 1, "maxLength": 96, "pattern": "^[a-z0-9][a-z0-9_-]*$" },
    "resultProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "digest"],
      "properties": {
        "name": { "const": "binary_scope_verification_v1" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "evidence_references"],
      "properties": {
        "state": { "enum": ["pass", "fail", "mixed", "detected", "not_detected", "unknown", "unavailable", "not_applicable", "not_evaluated", "manual_review_required"] },
        "evidence_references": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/evidenceReference" } }
      }
    },
    "evidenceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "digest", "bytes"],
      "properties": {
        "kind": { "enum": ["normalized_result", "final_output", "repository_diff", "test_result", "execution_event"] },
        "digest": { "$ref": "#/$defs/digest" },
        "bytes": { "type": ["integer", "null"], "minimum": 1 }
      }
    },
    "requirementResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_id", "outcome", "earned_points", "matched_equivalence_class_ids", "finding_ids", "evidence_references"],
      "properties": {
        "requirement_id": { "$ref": "#/$defs/token" },
        "outcome": { "enum": ["pass", "fail", "partial", "not_evaluated", "manual_review_required", "unavailable"] },
        "earned_points": { "type": ["number", "null"], "minimum": 0 },
        "matched_equivalence_class_ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/token" } },
        "finding_ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/token" } },
        "evidence_references": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/evidenceReference" } },
        "scope_deviation_references": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/token" } },
        "verification_evidence_references": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/evidenceReference" } }
      },
      "allOf": [
        {
          "if": { "properties": { "outcome": { "enum": ["pass", "fail", "partial"] } }, "required": ["outcome"] },
          "then": { "properties": { "evidence_references": { "minItems": 1 } } }
        }
      ]
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_id", "category", "severity", "evidence_references"],
      "properties": {
        "finding_id": { "$ref": "#/$defs/token" },
        "category": { "$ref": "#/$defs/token" },
        "severity": { "enum": ["critical", "high", "medium", "low", "informational"] },
        "evidence_references": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/evidenceReference" } }
      }
    },
    "mechanism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mechanism_id", "state", "evidence_references"],
      "properties": {
        "mechanism_id": { "$ref": "#/$defs/token" },
        "state": { "enum": ["observed", "missing", "unnecessary", "unknown", "not_applicable"] },
        "evidence_references": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/evidenceReference" } }
      }
    },
    "unsafeAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "category", "state", "evidence_references"],
      "properties": {
        "action_id": { "$ref": "#/$defs/token" },
        "category": { "$ref": "#/$defs/token" },
        "state": { "enum": ["attempted", "blocked", "unknown"] },
        "evidence_references": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/evidenceReference" } }
      }
    }
  }
}
