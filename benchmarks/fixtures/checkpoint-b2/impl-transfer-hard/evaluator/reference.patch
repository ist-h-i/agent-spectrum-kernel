+function assertExactKeys(object, allowed, required) {
+  if (!object || typeof object !== 'object' || Array.isArray(object)) {
+    throw new TransferValidationError('Expected an object');
+  }
+  const keys = Object.keys(object);
+  if (keys.some((key) => !allowed.includes(key)) || required.some((key) => !keys.includes(key))) {
+    throw new TransferValidationError('Object shape does not match schema');
+  }
 }
+
+export function normalizeTransferRequest(request) {
+  assertExactKeys(
+    request,
+    ['requestId', 'fromAccountId', 'toAccountId', 'amount', 'expectedVersions'],
+    ['requestId', 'fromAccountId', 'toAccountId', 'amount', 'expectedVersions']
+  );
+  if (typeof request.requestId !== 'string' || !/^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$/.test(request.requestId)) {
+    throw new TransferValidationError('Invalid request ID');
+  }
+  const fromAccountId = validateAccountId(request.fromAccountId);
+  const toAccountId = validateAccountId(request.toAccountId);
+  if (fromAccountId === toAccountId) throw new TransferValidationError('Accounts must be distinct');
+  const amount = validatePositiveAmount(request.amount);
+  assertExactKeys(request.expectedVersions, ['from', 'to'], ['from', 'to']);
+  if (!Number.isSafeInteger(request.expectedVersions.from) || request.expectedVersions.from < 0 ||
+      !Number.isSafeInteger(request.expectedVersions.to) || request.expectedVersions.to < 0) {
+    throw new TransferValidationError('Invalid expected versions');
+  }
+  const normalized = {
+    requestId: request.requestId,
+    fromAccountId,
+    toAccountId,
+    amount,
+    expectedVersions: { from: request.expectedVersions.from, to: request.expectedVersions.to }
+  };
+  return { ...normalized, fingerprint: JSON.stringify(normalized) };
+}
