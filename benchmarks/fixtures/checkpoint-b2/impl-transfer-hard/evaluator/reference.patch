@@ -0,0 +1,53 @@
+import test from 'node:test';
+import assert from 'node:assert/strict';
+import { AccountStore, TransferService } from '../src/index.mjs';
+
+const accounts = () => [
+  { id: 'acct_from1', currency: 'USD', balance: 100, minBalance: 0, version: 0 },
+  { id: 'acct_to001', currency: 'USD', balance: 10, minBalance: 0, version: 0 }
+];
+const request = (overrides = {}) => ({
+  requestId: 'request-1', fromAccountId: 'acct_from1', toAccountId: 'acct_to001', amount: 40,
+  expectedVersions: { from: 0, to: 0 }, ...overrides
+});
+
+test('audit failure rolls back and does not consume the transfer sequence', async () => {
+  let fail = true;
+  const store = new AccountStore(accounts(), { auditSink: async () => { if (fail) throw new Error('audit down'); } });
+  const service = new TransferService(store);
+  await assert.rejects(() => service.transfer(request()), /audit down/);
+  assert.equal(service.getAccount('acct_from1').balance, 100);
+  assert.deepEqual(service.listTransfers(), []);
+  fail = false;
+  assert.equal((await service.transfer(request())).transferId, 'tr_000001');
+});
+
+test('concurrent calls cannot both spend the same version and balance', async () => {
+  const service = new TransferService(new AccountStore(accounts()));
+  const outcomes = await Promise.allSettled([
+    service.transfer(request({ requestId: 'request-a', amount: 80 })),
+    service.transfer(request({ requestId: 'request-b', amount: 80 }))
+  ]);
+  assert.equal(outcomes.filter((outcome) => outcome.status === 'fulfilled').length, 1);
+  assert.equal(service.getAccount('acct_from1').balance, 20);
+  assert.equal(service.listTransfers().length, 1);
+});
+
+test('concurrent identical requests commit once', async () => {
+  let audits = 0;
+  const service = new TransferService(new AccountStore(accounts(), { auditSink: async () => { audits += 1; } }));
+  const [left, right] = await Promise.all([service.transfer(request()), service.transfer(request())]);
+  assert.deepEqual(left, right);
+  assert.equal(audits, 1);
+  assert.equal(service.listTransfers().length, 1);
+});
+
+test('receipt and history mutations cannot change account or stored history', async () => {
+  const service = new TransferService(new AccountStore(accounts()));
+  const receipt = await service.transfer(request());
+  receipt.from.balance = 999;
+  const history = service.listTransfers();
+  history[0].amount = 999;
+  assert.equal(service.getAccount('acct_from1').balance, 60);
+  assert.equal(service.listTransfers()[0].amount, 40);
+});
