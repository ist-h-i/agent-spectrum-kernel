@@ -0,0 +1,57 @@
+import test from 'node:test';
+import assert from 'node:assert/strict';
+import { IdempotencyConflictError, RuleService, RuleStore } from '../src/index.mjs';
+
+test('a later invalid operation rolls back the entire batch', () => {
+  const store = new RuleStore({ keep: true });
+  const service = new RuleService(store);
+  assert.throws(() => service.applyBatch({
+    requestId: 'req-rollback', expectedVersion: 0,
+    operations: [
+      { op: 'set', key: 'new', value: 1 },
+      { op: 'set', key: 'bad key', value: 2 }
+    ]
+  }));
+  assert.deepEqual(service.list(), { keep: true });
+  assert.equal(store.version, 0);
+});
+
+test('normalized replay returns the original receipt and collisions fail', () => {
+  const service = new RuleService(new RuleStore());
+  const first = service.applyBatch({
+    requestId: 'req-idem', expectedVersion: 0,
+    operations: [{ op: 'set', key: ' A ', value: 1 }]
+  });
+  service.put('other', 2);
+  assert.deepEqual(service.applyBatch({
+    requestId: 'req-idem', expectedVersion: 0,
+    operations: [{ op: 'set', key: 'a', value: 1 }]
+  }), first);
+  assert.throws(() => service.applyBatch({
+    requestId: 'req-idem', expectedVersion: 0,
+    operations: [{ op: 'set', key: 'a', value: 9 }]
+  }), IdempotencyConflictError);
+});
+
+test('duplicate canonical keys are rejected', () => {
+  const service = new RuleService(new RuleStore());
+  assert.throws(() => service.applyBatch({
+    requestId: 'req-dup', expectedVersion: 0,
+    operations: [
+      { op: 'set', key: ' Alpha ', value: true },
+      { op: 'delete', key: 'alpha' }
+    ]
+  }));
+});
+
+test('request and receipt mutations cannot change stored rules', () => {
+  const service = new RuleService(new RuleStore());
+  const request = {
+    requestId: 'req-alias', expectedVersion: 0,
+    operations: [{ op: 'set', key: 'a', value: 'original' }]
+  };
+  const receipt = service.applyBatch(request);
+  request.operations[0].value = 'input-change';
+  receipt.rules.a = 'receipt-change';
+  assert.equal(service.get('a'), 'original');
+});
