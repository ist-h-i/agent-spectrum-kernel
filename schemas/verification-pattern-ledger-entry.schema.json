{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ist-h-i/agent-spectrum-kernel/schemas/verification-pattern-ledger-entry.schema.json",
  "title": "Verification Pattern Ledger Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "change_type",
    "risk_class",
    "required_evidence",
    "recommended_focused_commands",
    "negative_cases",
    "regression_history",
    "known_flaky_areas",
    "applies_when",
    "do_not_use_when",
    "evidence_source",
    "evidence_status",
    "related_files_modules",
    "related_domain_rules",
    "related_engineering_patterns",
    "staleness_trigger",
    "owner"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "id": { "type": "string", "pattern": "^VP-[0-9]{4}$" },
    "change_type": { "type": "string", "minLength": 1 },
    "risk_class": { "type": "string", "minLength": 1 },
    "required_evidence": { "type": "string", "minLength": 1 },
    "recommended_focused_commands": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "negative_cases": { "type": "string", "minLength": 1 },
    "regression_history": { "type": "string", "minLength": 1 },
    "known_flaky_areas": { "type": "string", "minLength": 1 },
    "applies_when": { "type": "string", "minLength": 1 },
    "do_not_use_when": { "type": "string", "minLength": 1 },
    "evidence_source": { "type": "string", "minLength": 1 },
    "evidence_status": {
      "type": "string",
      "enum": ["Verified", "Human-confirmed", "Supported", "Hypothesis", "Deprecated", "Contradicted"]
    },
    "related_files_modules": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "related_domain_rules": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "related_engineering_patterns": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "staleness_trigger": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 }
  }
}
