{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ist-h-i/ai-coding-rules-and-skills/schemas/adoption-report.schema.json",
  "title": "AI Skills Adoption Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_type", "period", "summary", "privacy_note", "evidence_references"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "report_type": { "type": "string", "enum": ["weekly", "monthly", "custom"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string", "format": "date" },
        "end": { "type": "string", "format": "date" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tasks_reviewed": { "type": "integer", "minimum": 0 },
        "event_count": { "type": "integer", "minimum": 0 },
        "completed_tasks": { "type": "integer", "minimum": 0 },
        "validation_passed": { "type": "integer", "minimum": 0 },
        "validation_failed": { "type": "integer", "minimum": 0 },
        "insufficient_evidence": { "type": "integer", "minimum": 0 }
      }
    },
    "instruction_maturity": {
      "type": "object",
      "additionalProperties": false,
      "description": "Numeric values are null when the metric is unknown or unavailable; null is not zero.",
      "properties": {
        "average_goal_clarity": { "type": ["number", "null"], "minimum": 1, "maximum": 5 },
        "average_scope_clarity": { "type": ["number", "null"], "minimum": 1, "maximum": 5 },
        "average_context_sufficiency": { "type": ["number", "null"], "minimum": 1, "maximum": 5 },
        "verification_instruction_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "risk_awareness_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "stop_condition_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      }
    },
    "skill_usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skills_used": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "correct_routing_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1, "description": "Null means routing correctness was not recorded." },
        "required_gate_coverage": { "type": ["number", "null"], "minimum": 0, "maximum": 1, "description": "Null means required/executed gate data was not recorded." },
        "over_processing_count": { "type": "integer", "minimum": 0 },
        "missing_evidence_count": { "type": "integer", "minimum": 0 }
      }
    },
    "gate_decision_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total_decisions": { "type": "integer", "minimum": 0 },
        "missing_skip_reason_count": { "type": "integer", "minimum": 0 },
        "skipped_by_reason_category": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["category", "count"],
            "properties": {
              "category": { "type": "string", "minLength": 1 },
              "count": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "insufficient_evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["gate", "count"],
            "properties": {
              "gate": { "type": "string", "minLength": 1 },
              "layer": { "type": "string" },
              "count": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "under_processing_warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["gate", "count"],
            "properties": {
              "gate": { "type": "string", "minLength": 1 },
              "count": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "over_processing_warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["gate", "count"],
            "properties": {
              "gate": { "type": "string", "minLength": 1 },
              "count": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "gate_decision_drilldown": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_id", "gate", "status"],
        "properties": {
          "task_id": { "type": "string", "minLength": 1 },
          "gate": { "type": "string", "minLength": 1 },
          "layer": { "type": "string" },
          "status": { "type": "string", "enum": ["required", "executed", "skipped", "insufficient_evidence"] },
          "judgment": { "type": "string" },
          "evidence_checked": { "type": "array", "items": { "type": "string" } },
          "triggering_signals": { "type": "array", "items": { "type": "string" } },
          "missing_inputs": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "reason_category": { "type": "string" }
        }
      },
      "maxItems": 200
    },
    "review_quality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "review_tasks": { "type": "integer", "minimum": 0 },
        "decisions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "approve": { "type": "integer", "minimum": 0 },
            "approve_with_comments": { "type": "integer", "minimum": 0 },
            "request_changes": { "type": "integer", "minimum": 0 },
            "block": { "type": "integer", "minimum": 0 },
            "insufficient_evidence": { "type": "integer", "minimum": 0 }
          }
        },
        "required_fixes_count": { "type": "integer", "minimum": 0 },
        "insufficient_evidence_tasks": { "type": "integer", "minimum": 0 },
        "insufficient_evidence_layers": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "debt_movement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "detected": { "type": "integer", "minimum": 0 },
        "recorded": { "type": "integer", "minimum": 0 },
        "planned": { "type": "integer", "minimum": 0 },
        "in_progress": { "type": "integer", "minimum": 0 },
        "resolved": { "type": "integer", "minimum": 0 },
        "converted_to_rule": { "type": "integer", "minimum": 0 },
        "converted_to_check": { "type": "integer", "minimum": 0 },
        "accepted": { "type": "integer", "minimum": 0 },
        "wont_fix": { "type": "integer", "minimum": 0 },
        "stale": { "type": "integer", "minimum": 0 }
      }
    },
    "debt_inventory_snapshot": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "detected": { "type": "integer", "minimum": 0 },
        "recorded": { "type": "integer", "minimum": 0 },
        "open": { "type": "integer", "minimum": 0 },
        "triaged": { "type": "integer", "minimum": 0 },
        "accepted": { "type": "integer", "minimum": 0 },
        "planned": { "type": "integer", "minimum": 0 },
        "in_progress": { "type": "integer", "minimum": 0 },
        "resolved": { "type": "integer", "minimum": 0 },
        "converted_to_rule": { "type": "integer", "minimum": 0 },
        "converted_to_check": { "type": "integer", "minimum": 0 },
        "wont_fix": { "type": "integer", "minimum": 0 },
        "stale": { "type": "integer", "minimum": 0 }
      }
    },
    "adoption_effect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strong_signal": { "type": "array", "items": { "type": "string" } },
        "weak_signal": { "type": "array", "items": { "type": "string" } },
        "unknown": { "type": "array", "items": { "type": "string" } },
        "recommended_next_intervention": { "type": "string" }
      }
    },
    "evidence_references": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "privacy_note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_prompts_stored", "external_publication", "personnel_evaluation_boundary"],
      "properties": {
        "raw_prompts_stored": { "type": "boolean", "const": false },
        "external_publication": { "type": "boolean", "const": false },
        "personnel_evaluation_boundary": { "type": "string", "minLength": 1 },
        "sensitive_data_handling": { "type": "string" }
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "invalid_jsonl_lines": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
